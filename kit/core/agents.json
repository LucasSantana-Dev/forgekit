    "WebSearch": {
      "category": "web",
      "access": "network",
      "description": "Search external web sources"
    },
    "TodoWrite": {
      "category": "coordination",
      "access": "write",
      "description": "Track execution state with structured todos"
    },
    "Skill": {
      "category": "coordination",
      "access": "read",
      "description": "Load reusable skill instructions"
    },
    "Agent": {
      "category": "orchestration",
      "access": "delegate",
      "description": "Spawn or delegate work to specialist agents"
    },
    "MCP": {
      "category": "integration",
      "access": "network",
      "description": "Access external MCP-backed services"
