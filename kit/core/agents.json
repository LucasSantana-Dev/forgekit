    "FileRead": {
      "category": "filesystem",
      "access": "read",
      "description": "Read repository files and artifacts"
    },
    "FileWrite": {
      "category": "filesystem",
      "access": "write",
      "description": "Create and modify repository files"
    },
    "Glob": {
      "category": "filesystem",
      "access": "read",
      "description": "Find files by path pattern"
    },
    "Grep": {
      "category": "search",
      "access": "read",
      "description": "Search repository content"
    },
    "WebFetch": {
      "category": "web",
      "access": "network",
