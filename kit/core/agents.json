  "orgChart": {
    "orchestrator": {
      "directReports": [
        "architect",
        "reviewer",
        "writer",
        "researcher",
        "explorer"
      ],
      "description": "Top-level orchestrator manages all agents"
    },
    "architect": {
      "directReports": [
        "frontend",
        "backend",
        "devops",
        "tester",
        "security"
      ],
      "description": "CTO manages engineering specialists"
    },
    "reviewer": {
      "directReports": [
        "ts-reviewer",
        "python-reviewer",
        "go-reviewer",
        "rust-reviewer"
      ],
      "description": "Code reviewer manages language-specific review specialists"
    }
  },
  "orchestration": {
    "dispatch": {
      "strategy": "dependency-first",
      "maxPhases": 7,
      "verifyBetweenPhases": true,
      "parallelizeIndependent": true,
      "neverPauseFor": [
        "lint-fix",
        "type-fix",
        "test-fix",
        "commit",
        "push"
      ],
      "specialtyRouting": {
        "ui-work": "frontend",
        "api-work": "backend",
        "ci-cd": "devops",
        "testing": "tester",
        "security-scan": "security",
        "documentation": "writer",
        "code-review": "reviewer",
        "ts-review": "ts-reviewer",
        "python-review": "python-reviewer",
        "go-review": "go-reviewer",
        "rust-review": "rust-reviewer",
        "research": "researcher",
        "file-search": "explorer",
        "architecture": "architect",
        "rag-pipeline": "backend",
        "vector-search": "backend",
        "document-retrieval": "researcher",
        "llm-eval": "orchestrator",
        "agent-recovery": "orchestrator",
        "error-recovery": "orchestrator",
        "mcp-server": "backend",
        "tool-schema": "backend",
        "multi-agent": "orchestrator",
        "dag-execution": "orchestrator",
        "agent-teams": "orchestrator",
        "model-serving": "devops",
        "inference-server": "devops",
        "ai-observability": "devops"
      }
    },
    "escalation": {
      "workerFails2x": "consult-architect-then-continue",
      "explorerEmpty": "promote-to-researcher",
      "reviewFindsArchIssue": "consult-architect-async",
      "modelUnavailable": "fallback-chain",
      "specialistUnavailable": "fall-back-to-worker"
    },
    "loop": {
      "defaultMode": "autonomous",
      "phases": [
        "plan",
        "implement",
        "verify",
        "review",
        "fix",
        "commit"
      ],
      "exitCondition": "all-phases-complete-and-quality-gates-pass",
      "autoResume": true
    },
    "session": {
      "resumeFromPlan": true,
      "persistStateOnInterrupt": true,
      "planDirectory": ".agents/plans/"
    }
  }
}