{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mcp.schema.json",
  "type": "object",
  "required": ["$schema", "version", "mcpServers", "profiles", "agentMapping"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "mcpServers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "command",
          "args",
          "description",
          "required_env",
          "profile"
        ],
        "properties": {
          "command": { "type": "string" },
          "args": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "description": { "type": "string" },
          "required_env": { "type": "array", "items": { "type": "string" } },
          "profile": {
            "type": "string",
            "enum": ["minimal", "standard", "full"]
          },
          "category": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "servers"],
        "properties": {
          "description": { "type": "string" },
          "servers": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "agentMapping": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
