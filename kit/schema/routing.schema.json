{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "routing.schema.json",
  "type": "object",
  "required": ["$schema", "version", "tiers", "categories", "providers"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "tiers": { "type": "object", "minProperties": 1 },
    "categories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["tier"],
        "properties": {
          "tier": { "type": "string", "enum": ["haiku", "sonnet", "opus"] }
        },
        "additionalProperties": true
      }
    },
    "classifier": { "type": "object" },
    "providers": { "type": "object", "minProperties": 1 },
    "heuristics": { "type": "object" }
  },
  "additionalProperties": true
}
