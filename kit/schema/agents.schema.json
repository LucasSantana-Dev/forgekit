{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agents.schema.json",
  "type": "object",
  "required": ["$schema", "version", "agents"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["tier", "title", "role", "tools"],
        "properties": {
          "tier": { "type": "string", "enum": ["haiku", "sonnet", "opus"] },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "tools": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "reportsTo": { "type": ["string", "null"] },
          "fallback": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "orgChart": { "type": "object" },
    "orchestration": { "type": "object" }
  },
  "additionalProperties": true
}
