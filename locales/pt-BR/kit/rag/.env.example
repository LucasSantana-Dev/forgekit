# ai-dev-toolkit kit/rag — portable configuration
# Copy to ~/.claude/rag-index/.env (or export the vars in your shell) to customize.
# Every variable has a sensible default; only override what applies to your setup.

# --------- Paths ---------
# Where the index + scripts live. Must match where install-rag.sh dropped them.
# RAG_HOME=~/.claude/rag-index

# Where the claude-code memory/skills/plans live. Friends on Cursor / Codex-only
# setups can point this elsewhere or leave empty to skip.
# RAG_CLAUDE_ROOT=~/.claude

# --------- Sources ---------
# Colon-separated list of curated repo paths. Used for:
#   - code ingestion (src/**, language-aware chunking)
#   - CHANGELOG / README / docs/**/*.md
#   - git log (last 180 days, subject + body head)
#   - docs/specs/**/*.md + docs/roadmap.md
# RAG_REPOS="$HOME/code/repo-a:$HOME/code/repo-b"

# Extra markdown globs to index as source_type=memory. Colon-separated.
# RAG_EXTRA_MD_GLOBS=""

# --------- Work-mode safety ---------
# Set to 1 to skip indexing of personal memory/plans/handoffs even when present.
# Useful on a work laptop where you want only repo-local docs + code indexed.
# RAG_WORK_MODE=0

# --------- Embeddings ---------
# Default model. Change only if you also rebuild from scratch.
# RAG_MODEL=all-MiniLM-L6-v2

# Run fully offline (no Hugging Face Hub calls). Recommended once model cache warm.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# --------- Reranker ---------
# Default-on for explicit queries; forced off for autorecall hooks.
# RAG_RERANK=on

# --------- Auto-recall hook ---------
# off | quiet (threshold 0.35) | loud (threshold 0.28)
# CLAUDE_RAG_AUTORECALL=quiet

# --------- Observability ---------
# Turn off per-query logging if desired.
# RAG_QLOG=on
