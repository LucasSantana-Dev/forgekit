{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agents.schema.json",
  "type": "object",
  "required": ["$schema", "version", "toolRegistry", "agents"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "toolRegistry": {
      "type": "object",
      "minProperties": 1,
      "required": [
        "Bash",
        "FileRead",
        "FileWrite",
        "Glob",
        "Grep",
        "WebFetch",
        "WebSearch",
        "TodoWrite",
        "Skill",
        "Agent",
        "MCP",
        "LSP"
      ],
      "additionalProperties": {
        "type": "object",
        "required": ["category", "access", "description"],
        "properties": {
          "category": { "type": "string" },
          "access": {
            "type": "string",
            "enum": ["read", "write", "network", "delegate"]
          },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["tier", "title", "role", "tools"],
        "properties": {
          "tier": { "type": "string", "enum": ["haiku", "sonnet", "opus"] },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "tools": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "Bash",
                "FileRead",
                "FileWrite",
                "Glob",
                "Grep",
                "WebFetch",
                "WebSearch",
                "TodoWrite",
                "Skill",
                "Agent",
                "MCP",
                "LSP"
              ]
            }
          },
          "reportsTo": { "type": ["string", "null"] },
          "fallback": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "orgChart": { "type": "object" },
    "orchestration": { "type": "object" }
  },
  "additionalProperties": true
}
