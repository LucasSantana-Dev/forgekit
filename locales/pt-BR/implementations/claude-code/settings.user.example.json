{
  "permissions": {
    "allow": ["Read", "Glob", "Grep", "LS"],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force origin main)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/ai-dev-toolkit/implementations/claude-code/hooks/pre-tool-use.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf 'Claude Code'"
  },
  "enabledPlugins": [],
  "extraKnownMarketplaces": [],
  "modelOverrides": {}
}
