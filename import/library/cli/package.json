{
  "name": "@lucassantana/adtl",
  "version": "0.1.0",
  "description": "CLI for ai-dev-toolkit-library: browse, install skills, register MCP servers with your local gateway.",
  "keywords": ["mcp", "claude", "skills", "ai", "cli"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "adtl": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LucasSantana-Dev/ai-dev-toolkit-library.git",
    "directory": "cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
