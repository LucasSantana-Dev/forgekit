{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucassantana-dev.github.io/ai-dev-toolkit-library/schemas/doc.schema.json",
  "title": "Doc",
  "description": "Reference material rendered on the site. No install verb.",
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "upstream": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "translations": {
      "type": "object",
      "description": "Optional locale-specific overrides for user-visible fields. Keys are BCP-47 language tags.",
      "additionalProperties": false,
      "properties": {
        "pt-BR": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
