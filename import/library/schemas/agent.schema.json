{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucassantana-dev.github.io/ai-dev-toolkit-library/schemas/agent.schema.json",
  "title": "Agent",
  "description": "A Claude Code sub-agent installable into ~/.claude/agents/<id>.md.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true
    },
    "model": {
      "type": "string",
      "description": "Model ID the sub-agent uses (e.g. claude-opus-4-6, claude-sonnet-4-6)."
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Permission / autonomy level, if the source used one."
    },
    "disallowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tools explicitly denied to this sub-agent."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "git",
            "local",
            "vendored"
          ]
        },
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "maxLength": 64
    },
    "author": {
      "type": "string",
      "maxLength": 128
    },
    "deprecated": {
      "type": "boolean",
      "default": false
    },
    "translations": {
      "type": "object",
      "description": "Optional locale-specific overrides for user-visible fields. Keys are BCP-47 language tags.",
      "additionalProperties": false,
      "properties": {
        "pt-BR": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
