# Cloudflare static-asset headers — applied at the edge to every response.
# Spec: https://developers.cloudflare.com/pages/configuration/headers/
#
# Astro copies `public/_headers` into `dist/_headers` on build, where
# Cloudflare's static-asset router picks it up.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Long-cache hashed assets — Astro emits content-hashed filenames under /_astro/
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images and the favicon
/favicon.svg
  Cache-Control: public, max-age=86400
/og-image.svg
  Cache-Control: public, max-age=86400

# llms.txt and sitemap should refresh more often than HTML pages
/llms.txt
  Cache-Control: public, max-age=3600
/llms-full.txt
  Cache-Control: public, max-age=3600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
