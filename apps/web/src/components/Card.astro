---
import { displayEntryName, kindLabel, providerLabel, type Kind, type Provider } from "../lib/ui.ts";

interface Props {
  kind: Kind;
  id: string;
  name: string;
  description: string;
  tags?: string[];
  href: string;
  extraTag?: string;
  provider?: Provider;
  /** Kept for backwards compatibility; the redesigned card always shows the id row instead of the kind chip. */
  hideKind?: boolean;
}
const { kind, id, name, description, tags = [], href, extraTag, provider } = Astro.props;
const label = kindLabel(kind);
const displayName = displayEntryName(name);
const haystack = [id, name, description, ...tags].join(" ").toLowerCase();

function stripMd(text: string): string {
  return text
    .replace(/#{1,6}\s+/g, "")
    .replace(/\*\*(.+?)\*\*/g, "$1")
    .replace(/\*(.+?)\*/g, "$1")
    .replace(/`{1,3}[^`]*`{1,3}/g, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/^\s*[-*+]\s+/gm, "")
    .trim();
}
---
<a
  class="card card-terminal"
  href={href}
  data-kind={kind}
  data-tags={tags.join(",")}
  data-search={haystack}
  style={`--card-accent: var(--kind-${kind})`}
>
  <div class="card-head">
    <span class="card-dot" aria-hidden="true" title={label}></span>
    <span class="card-id">{id}</span>
    {provider && (
      <span class={`card-provider card-provider-${provider}`} aria-label={`Provider: ${providerLabel(provider)}`}>
        {provider}
      </span>
    )}
  </div>
  <div class="card-body">
    <h3>{displayName}</h3>
    <p>{stripMd(description)}</p>
  </div>
  <div class="card-footer">
    <div class="tags">
      {extraTag && <span class="tag tag-extra">{extraTag}</span>}
      {tags.slice(0, 3).map((t) => <span class="tag">#{t}</span>)}
      {tags.length > 3 && <span class="tag tag-more">+{tags.length - 3}</span>}
    </div>
    <span class="card-arrow" aria-hidden="true">↗</span>
  </div>
</a>

<style>
  .card-provider {
    margin-left: auto;
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    border: 1px solid currentColor;
    opacity: 0.55;
    line-height: 1.5;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .card-provider-claude  { color: oklch(75% 0.08 75); }
  .card-provider-codex   { color: oklch(72% 0.16 145); }
  .card-provider-gemini  { color: oklch(72% 0.14 250); }
  .card-provider-cursor  { color: oklch(70% 0.14 320); }
  .card-provider-local   { color: oklch(70% 0.05 200); }
  .card-provider-any     { color: var(--fg-subtle); }
</style>
