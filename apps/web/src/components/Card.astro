---
import { displayEntryName, kindGlyph, kindLabel, type Kind } from "../lib/ui.ts";

interface Props {
  kind: Kind;
  id: string;
  name: string;
  description: string;
  tags?: string[];
  href: string;
  extraTag?: string;
}
const { kind, id, name, description, tags = [], href, extraTag } = Astro.props;
const icon = kindGlyph(kind);
const label = kindLabel(kind);
const displayName = displayEntryName(name);
const haystack = [id, name, description, ...tags].join(" ").toLowerCase();
---
<a
  class="card"
  href={href}
  data-kind={kind}
  data-tags={tags.join(",")}
  data-search={haystack}
  style={`--card-accent: var(--kind-${kind})`}
>
  <div class="card-top">
    <span class="icon">{icon}</span>
    <span class={`kind kind-${kind}`}>{label}</span>
  </div>
  <div class="card-body">
    <h3>{displayName}</h3>
    <p>{description}</p>
  </div>
  {(extraTag || tags.length > 0) && (
    <div class="card-footer">
      <div class="tags">
        {extraTag && <span class="tag tag-extra">{extraTag}</span>}
        {tags.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
        {tags.length > 2 && <span class="tag tag-more">+{tags.length - 2}</span>}
      </div>
      <span class="card-arrow" aria-hidden="true">↗</span>
    </div>
  )}
</a>
