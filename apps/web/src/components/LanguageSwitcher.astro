---
import type { Locale } from "../lib/i18n";
import { switchLocalePath, t } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const path = Astro.url.pathname;
const suffix = `${Astro.url.search}${Astro.url.hash}`;
const hrefFor = (target: Locale) => `${switchLocalePath(path, target)}${suffix}`;
---
<div class="lang" role="group" aria-label={t("language.label", locale)}>
  <a
    class:list={["lang-option", locale === "en" && "active"]}
    href={hrefFor("en")}
    aria-current={locale === "en" ? "page" : undefined}
    title={t("language.en", locale)}
  >
    <span>EN</span>
    <small>{t("language.en", locale)}</small>
  </a>
  <a
    class:list={["lang-option", locale === "pt-br" && "active"]}
    href={hrefFor("pt-br")}
    aria-current={locale === "pt-br" ? "page" : undefined}
    title={t("language.pt-br", locale)}
  >
    <span>PT-BR</span>
    <small>{t("language.pt-br", locale)}</small>
  </a>
</div>

<style>
  .lang {
    display: inline-grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 0.2rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    gap: 0.15rem;
  }
  .lang-option {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 5.15rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    color: var(--fg-subtle);
    text-decoration: none;
    font-size: 0.78rem;
    line-height: 1.05;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
  }
  .lang-option small {
    font-size: 0.66rem;
    letter-spacing: 0.02em;
    text-transform: none;
    opacity: 0.82;
  }
  .lang-option:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }
  .lang-option.active,
  .lang-option[aria-current="page"] {
    background: rgba(255, 255, 255, 0.08);
    color: var(--fg);
  }
  .lang-option:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (max-width: 640px) {
    .lang-option {
      min-width: 3.9rem;
      padding: 0.4rem 0.55rem;
    }
    .lang-option small {
      display: none;
    }
  }
</style>
