---
import Card from "./Card.astro";
import type { Collection } from "../lib/catalog";
import type { Locale } from "../lib/i18n";
import { pluralizeItems } from "../lib/i18n";

interface Props {
  collections: Collection[];
  locale: Locale;
  hrefFor: (id: string) => string;
  heading?: string;
  lede?: string;
}

const { collections, locale, hrefFor, heading, lede } = Astro.props;
const featured = collections.slice(0, 3);
const remaining = collections.slice(3);
---
{(heading || lede) && (
  <div class="section-collections-header">
    {heading && <div class="section-title">{heading}</div>}
    {lede && <p class="section-lede">{lede}</p>}
  </div>
)}
<div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
  {featured.map((c) => (
    <Card
      kind="collection"
      id={c.id}
      name={c.name}
      description={c.description}
      tags={c.tags ?? []}
      href={hrefFor(c.id)}
      extraTag={pluralizeItems(c.items.length, locale)}
    />
  ))}
</div>
{remaining.length > 0 && (
  <div class="grid remaining-grid" style="margin-top: 1.25rem;">
    {remaining.map((c) => (
      <Card
        kind="collection"
        id={c.id}
        name={c.name}
        description={c.description}
        tags={c.tags ?? []}
        href={hrefFor(c.id)}
        extraTag={pluralizeItems(c.items.length, locale)}
      />
    ))}
  </div>
)}
