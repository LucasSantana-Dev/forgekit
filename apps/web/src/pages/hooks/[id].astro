---
import Base from "../../layouts/Base.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import UsageBlock from "../../components/UsageBlock.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import { getHooks, getTutorials } from "../../lib/catalog.ts";
import { installCommand } from "../../lib/ui.ts";

export async function getStaticPaths() {
  const hooks = await getHooks();
  return hooks.map((h) => ({ params: { id: h.id }, props: { hook: h } }));
}
const { hook } = Astro.props;
const cmd = installCommand("hook", hook.id)!;
const tutorials = await getTutorials();
const base = import.meta.env.BASE_URL;
---
<Base title={hook.name} description={hook.description}>
  <EntryHeader kind="hook" name={hook.name} description={hook.description} backLabel="All hooks">
    <div class="entry-tags">
      <span class="tag">event: {hook.event}</span>
      <span class="tag">runtime: {hook.runtime}</span>
      {hook.matcher && <span class="tag">matcher: {hook.matcher}</span>}
      {hook.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={hook.usage} locale="en" />

  <h2>Script</h2>
  <pre><code>{hook.script}</code></pre>

  {hook.source?.path && (
    <p class="entry-source">
      Source: <code>{hook.source.path}</code>
      {hook.license && <> · {hook.license}</>}
    </p>
  )}

  <RelatedTutorials kind="hook" id={hook.id} tutorials={tutorials} base={base} />
</Base>
