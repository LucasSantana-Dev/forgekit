---
import Base from "../../layouts/Base.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import UsageBlock from "../../components/UsageBlock.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import RelatedCollections from "../../components/RelatedCollections.astro";
import { getSkills, getTutorials, getCollections } from "../../lib/catalog.ts";
import { installCommand, renderMarkdown, deriveProvider, splitIntoTabs } from "../../lib/ui.ts";
import TabStrip from "../../components/TabStrip.astro";

export async function getStaticPaths() {
  const skills = await getSkills();
  return skills.map((s) => ({ params: { id: s.id }, props: { skill: s } }));
}
const { skill } = Astro.props;
const rendered = renderMarkdown(skill.body);
const tabs = splitIntoTabs(rendered);
const cmd = installCommand("skill", skill.id)!;
const tutorials = await getTutorials();
const collections = await getCollections();
const base = import.meta.env.BASE_URL;

// Externally-sourced skills are not re-hosted here — forgekit links to them.
// `getSkills` leaves `body` empty when no SKILL.md is vendored in the catalog.
const hasBody = skill.body.trim().length > 0;
const src = skill.source;
const sourceUrl =
  skill.homepage ??
  (src?.repo && src.path ? `${src.repo.replace(/\.git$/, "")}/blob/${src.ref ?? "main"}/${src.path}` : null) ??
  src?.repo ??
  null;
const sourceLabel = src?.repo?.replace(/^https?:\/\/(www\.)?github\.com\//, "") ?? src?.path ?? sourceUrl;
---
<Base title={skill.name} description={skill.description}>
  <EntryHeader kind="skill" name={skill.name} description={skill.description} backLabel="All skills" provider={deriveProvider(skill.tags)}>
    <div class="entry-tags">
      {skill.version && <span class="tag">v{skill.version}</span>}
      {skill.editors?.map((e) => <span class="tag">{e}</span>)}
      {skill.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={skill.usage} locale="en" />

  {hasBody ? (
    tabs ? (
      <TabStrip preamble={tabs.preamble} tabs={tabs.tabs} />
    ) : (
      <article class="markdown mt-4" set:html={rendered} />
    )
  ) : (
    <div class="entry-external mt-4">
      <p>This skill is maintained upstream — forgekit links to it rather than re-hosting a copy.</p>
      {sourceUrl && (
        <p>
          <a href={sourceUrl} target="_blank" rel="noopener noreferrer">View the full skill at source ↗</a>
        </p>
      )}
    </div>
  )}

  {(sourceUrl || skill.source?.path || skill.license) && (
    <p class="entry-source">
      {sourceUrl ? (
        <>Source: <a href={sourceUrl} target="_blank" rel="noopener noreferrer">{sourceLabel}</a></>
      ) : (
        skill.source?.path && <>Source: <code>{skill.source.path}</code></>
      )}
      {skill.license && <>{(sourceUrl || skill.source?.path) ? " · " : "License: "}{skill.license}</>}
    </p>
  )}

  <RelatedCollections kind="skill" id={skill.id} collections={collections} base={base} />
  <RelatedTutorials kind="skill" id={skill.id} tutorials={tutorials} base={base} />
</Base>
