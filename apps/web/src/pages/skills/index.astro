---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import SearchFilter from "../../components/SearchFilter.astro";
import { getSkills } from "../../lib/catalog.ts";

const skills = await getSkills();
const base = import.meta.env.BASE_URL;

const tagSet = new Set<string>();
for (const s of skills) for (const t of s.tags) tagSet.add(t);
const tags = [...tagSet].sort();
---
<Base title="Skills" description={`${skills.length} skills for AI-assisted dev.`}>
  <h1>Skills</h1>
  <p class="lead-muted">
    Actionable procedures. Install with <code>npx forge-kit install &lt;id&gt;</code>.
    Lands in <code>~/.claude/skills/&lt;id&gt;/</code>.
  </p>
  <SearchFilter placeholder={`Search ${skills.length} skills…`} tags={tags} />
  <div class="grid">
    {skills.map((s) => (
      <Card
        kind="skill"
        id={s.id}
        name={s.name}
        description={s.description}
        tags={s.tags}
        href={`${base}skills/${s.id}/`}
      />
    ))}
  </div>
  <div id="empty-state" class="empty" style="display: none;">No skills match your filters.</div>
</Base>
