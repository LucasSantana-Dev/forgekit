---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import SearchFilter from "../../components/SearchFilter.astro";
import { getCommands } from "../../lib/catalog.ts";

const commands = await getCommands();
const base = import.meta.env.BASE_URL;

const byCategory = commands.reduce<Record<string, typeof commands>>((acc, c) => {
  const cat = c.category ?? "Other";
  (acc[cat] ??= []).push(c);
  return acc;
}, {});
const categories = Object.keys(byCategory).sort();

const tagSet = new Set<string>();
for (const c of commands) for (const t of c.tags) tagSet.add(t);
const tags = [...tagSet].sort();

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "");
---
<Base title="Commands" description={`Browse ${commands.length} Claude Code slash commands — quick triggers for common workflows like commit, review, plan, ship, and ticket creation.`}>
  <h1>Commands</h1>
  <p class="lead-muted">
    Claude Code slash commands. Install with
    <code>npx forge-kit install &lt;id&gt;</code> → lands in
    <code>~/.claude/commands/&lt;id&gt;.md</code>.
  </p>
  {commands.length === 0 ? (
    <div class="empty-page">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M7 9h4M7 12h6M7 15h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M16 12l2 2-2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="empty-title">No commands yet</p>
      <p class="empty-sub">Be the first to contribute a slash command to the catalog.</p>
      <code class="empty-cta">docs/ADD_A_COMMAND.md</code>
    </div>
  ) : (
    <>
      <SearchFilter placeholder={`Search ${commands.length} commands…`} tags={tags} />
      <div class="page-layout">
        <div class="page-main">
          {categories.map((category) => (
            <section class="entry-category" id={slugify(category)}>
              <div class="category-header">
                <h2 class="category-title">{category}</h2>
                <span class="category-count">{byCategory[category].length}</span>
              </div>
              <div class="grid">
                {byCategory[category].map((c) => (
                  <Card
                    kind="command"
                    id={c.id}
                    name={c.name}
                    description={c.description}
                    tags={c.tags}
                    href={`${base}commands/${c.id}/`}
                    extraTag={c.category}
                    hideKind={true}
                  />
                ))}
              </div>
            </section>
          ))}
          <div id="empty-state" class="empty" style="display: none;">No commands match your filters.</div>
        </div>

        {categories.length > 1 && (
          <aside class="page-sidebar">
            <div class="sidebar-heading">Categories</div>
            <nav aria-label="Jump to category">
              {categories.map((category) => (
                <a class="sidebar-link" href={`#${slugify(category)}`}>
                  <span class="sidebar-dot" aria-hidden="true"></span>
                  <span class="sidebar-label">{category}</span>
                  <span class="sidebar-count">{byCategory[category].length}</span>
                </a>
              ))}
            </nav>
          </aside>
        )}
      </div>
    </>
  )}
</Base>

<style>
  .page-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 2.5rem;
    align-items: start;
  }
  .page-main {
    min-width: 0;
  }
  .page-sidebar { position: sticky; top: 5rem; }
  .sidebar-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-subtle);
    padding: 0 0.85rem;
    margin-bottom: 0.5rem;
  }
  .page-sidebar nav { display: flex; flex-direction: column; gap: 0.1rem; }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    border-radius: 8px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--fg-subtle);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sidebar-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--kind-command, var(--fg-subtle));
    opacity: 0.5; flex-shrink: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .sidebar-label { flex: 1; min-width: 0; }
  .sidebar-link:hover { background: rgba(255, 255, 255, 0.06); color: var(--fg); }
  .sidebar-link:hover .sidebar-dot { opacity: 0.85; }
  .sidebar-link.is-active { background: rgba(255, 255, 255, 0.06); color: var(--fg); }
  .sidebar-link.is-active .sidebar-dot { opacity: 1; transform: scale(1.2); }
  .sidebar-count { font-size: 0.78rem; opacity: 0.6; flex-shrink: 0; }
  .entry-category {
    scroll-margin-top: 5rem;
    margin-bottom: 3rem;
  }
  .category-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .category-title {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
    margin: 0;
  }
  .category-count {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg-muted, var(--fg-subtle));
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .page-layout { grid-template-columns: 1fr; }
    .page-sidebar { position: static; order: -1; }
    .sidebar-heading { display: none; }
    .page-sidebar nav { flex-direction: row; flex-wrap: wrap; }
    .sidebar-link { border: 1px solid var(--border); border-radius: 999px; padding: 0.3rem 0.7rem; }
  }
</style>
