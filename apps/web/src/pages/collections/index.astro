---
import Base from "../../layouts/Base.astro";
import CollectionsFeaturedGrid from "../../components/CollectionsFeaturedGrid.astro";
import { getCollections } from "../../lib/catalog.ts";
import { t, type Locale } from "../../lib/i18n.ts";

const locale: Locale = "en";
const collectionsRaw = await getCollections();
const collections = [...collectionsRaw].sort((a, b) => b.items.length - a.items.length);
const base = import.meta.env.BASE_URL;
---
<Base title={t("list.collections.title", locale)} description={t("list.collections.description", locale, { count: collections.length })}>
  <h1>{t("list.collections.title", locale)}</h1>
  <CollectionsFeaturedGrid
    collections={collections}
    locale={locale}
    hrefFor={(id) => `${base}collections/${id}/`}
    heading={t("list.collections.intro", locale)}
    lede={t("list.collections.introLede", locale)}
  />
</Base>
