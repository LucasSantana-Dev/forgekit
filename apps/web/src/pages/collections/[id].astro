---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import {
  buildCollectionItemResolver,
  collectionItemPath,
  getCatalogData,
  getCollections,
  getTutorials,
} from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const collections = await getCollections();
  return collections.map((c) => ({ params: { id: c.id }, props: { collection: c } }));
}

const catalog = await getCatalogData();
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;

const resolveItem = buildCollectionItemResolver(catalog, (item) => `${base}${collectionItemPath(item)}`);
const tutorials = await getTutorials();
---
<Base title={collection.name} description={collection.description}>
  <EntryHeader kind="collection" name={collection.name} description={collection.description} backLabel="All collections">
    {collection.tags && collection.tags.length > 0 && (
      <div class="entry-tags">
        {collection.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </EntryHeader>

  <h2>Items ({collection.items.length})</h2>
  <div class="grid">
    {collection.items.map((item) => <Card {...resolveItem(item)} />)}
  </div>

  <RelatedTutorials kind="collection" id={collection.id} tutorials={tutorials} base={base} />
</Base>
