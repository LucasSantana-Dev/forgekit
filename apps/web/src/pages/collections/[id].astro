---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import {
  buildCollectionItemResolver,
  collectionItemPath,
  getCatalogData,
  getCollections,
} from "../../lib/catalog.ts";

export async function getStaticPaths() {
  const collections = await getCollections();
  return collections.map((c) => ({ params: { id: c.id }, props: { collection: c } }));
}

const catalog = await getCatalogData();
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;

const resolveItem = buildCollectionItemResolver(catalog, (item) => `${base}${collectionItemPath(item)}`);
---
<Base title={collection.name} description={collection.description}>
  <p style="margin-bottom: 1.5rem;"><a href="../">← all collections</a></p>
  <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.6rem;">📦</span>
    <h1 style="margin: 0;">{collection.name}</h1>
    <span class="kind kind-collection">collection</span>
  </div>
  <p class="lead-muted" style="margin-bottom: 1rem;">{collection.description}</p>
  {collection.tags && collection.tags.length > 0 && (
    <div class="tags" style="margin-bottom: 1.5rem;">
      {collection.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}

  <h2>Items ({collection.items.length})</h2>
  <div class="grid">
    {collection.items.map((item) => <Card {...resolveItem(item)} />)}
  </div>
</Base>
