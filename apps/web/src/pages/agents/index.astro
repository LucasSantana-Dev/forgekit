---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import SearchFilter from "../../components/SearchFilter.astro";
import { getAgents } from "../../lib/catalog.ts";

const agents = await getAgents();
const base = import.meta.env.BASE_URL;

const tagSet = new Set<string>();
for (const a of agents) for (const t of a.tags) tagSet.add(t);
const tags = [...tagSet].sort();
---
<Base title="Agents" description={`${agents.length} Claude Code sub-agents.`}>
  <h1>Agents</h1>
  <p class="lead-muted">
    Claude Code sub-agents. Install with <code>npx forge-kit install &lt;id&gt;</code> —
    lands in <code>~/.claude/agents/&lt;id&gt;.md</code>.
  </p>
  <SearchFilter placeholder={`Search ${agents.length} agents…`} tags={tags} />
  <div class="grid">
    {agents.map((a) => (
      <Card
        kind="agent"
        id={a.id}
        name={a.name}
        description={a.description}
        tags={a.tags}
        href={`${base}agents/${a.id}/`}
        extraTag={a.model}
      />
    ))}
  </div>
  <div id="empty-state" class="empty" style="display: none;">No agents match your filters.</div>
</Base>
