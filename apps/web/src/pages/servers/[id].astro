---
import Base from "../../layouts/Base.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import UsageBlock from "../../components/UsageBlock.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import RelatedCollections from "../../components/RelatedCollections.astro";
import { getServers, getTutorials, getCollections } from "../../lib/catalog.ts";
import { installCommand, deriveProvider } from "../../lib/ui.ts";

export async function getStaticPaths() {
  const servers = await getServers();
  return servers.map((s) => ({ params: { id: s.id }, props: { server: s } }));
}
const { server } = Astro.props;

const cmd = installCommand("server", server.id)!;
const tutorials = await getTutorials();
const collections = await getCollections();
const base = import.meta.env.BASE_URL;
const runCmd =
  server.transport === "stdio"
    ? `${server.command ?? ""} ${(server.args ?? []).join(" ")}`.trim()
    : server.url ?? "";
---
<Base title={server.name} description={server.description}>
  <EntryHeader kind="server" name={server.name} description={server.description} backLabel="All servers" provider={deriveProvider(server.tags)}>
    <div class="entry-tags">
      <span class="tag">transport: {server.transport}</span>
      {server.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={server.usage} locale="en" />

  <h2>How it runs</h2>
  <pre><code>{runCmd}</code></pre>

  {server.env && server.env.length > 0 && (
    <>
      <h2>Environment variables</h2>
      <ul class="markdown">
        {server.env.map((e) => (
          <li>
            <code>{e.name}</code>
            {e.required ? " (required)" : " (optional)"}
            {e.description && <> — {e.description}</>}
          </li>
        ))}
      </ul>
    </>
  )}

  {(server.homepage || server.license) && (
    <p class="entry-source">
      {server.homepage && <>Homepage: <a href={server.homepage}>{server.homepage}</a></>}
      {server.license && <>{server.homepage ? " · " : ""}{server.license}</>}
    </p>
  )}

  <RelatedCollections kind="server" id={server.id} collections={collections} base={base} />
  <RelatedTutorials kind="server" id={server.id} tutorials={tutorials} base={base} />
</Base>
