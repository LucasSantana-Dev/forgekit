---
import Base from "../../layouts/Base.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import UsageBlock from "../../components/UsageBlock.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import RelatedCollections from "../../components/RelatedCollections.astro";
import { getTools, getTutorials, getCollections } from "../../lib/catalog.ts";
import { installCommand, deriveProvider } from "../../lib/ui.ts";

export async function getStaticPaths() {
  const tools = await getTools();
  return tools.map((t) => ({ params: { id: t.id }, props: { tool: t } }));
}
const { tool } = Astro.props;
const cmd = installCommand("tool", tool.id)!;
const tutorials = await getTutorials();
const collections = await getCollections();
const base = import.meta.env.BASE_URL;
---
<Base title={tool.name} description={tool.description}>
  <EntryHeader kind="tool" name={tool.name} description={tool.description} backLabel="All tools" provider={deriveProvider(tool.tags)}>
    <div class="entry-tags">
      <span class="tag">runtime: {tool.runtime}</span>
      <span class="tag">category: {tool.category}</span>
      {tool.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={tool.usage} locale="en" />

  {tool.install?.dependencies && tool.install.dependencies.length > 0 && (
    <>
      <h2>Dependencies</h2>
      <ul class="markdown">
        {tool.install.dependencies.map((d) => <li><code>{d}</code></li>)}
      </ul>
    </>
  )}

  <h2>Script</h2>
  <pre><code>{tool.script}</code></pre>

  {tool.source?.path && (
    <p class="entry-source">
      Source: <code>{tool.source.path}</code>
      {tool.license && <> · {tool.license}</>}
    </p>
  )}

  <RelatedCollections kind="tool" id={tool.id} collections={collections} base={base} />
  <RelatedTutorials kind="tool" id={tool.id} tutorials={tutorials} base={base} />
</Base>
