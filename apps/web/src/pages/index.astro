---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CollectionsFeaturedGrid from "../components/CollectionsFeaturedGrid.astro";
import InstallBlock from "../components/InstallBlock.astro";
import {
  getSkills,
  getServers,
  getCollections,
  getDocs,
  getAgents,
  getHooks,
  getCommands,
  getTools,
} from "../lib/catalog.ts";
import { buildHomepageCuration } from "../lib/curation.ts";
import { localizeEntries, t, localizedUrl, type Locale } from "../lib/i18n.ts";
import { displayEntryName } from "../lib/ui.ts";

const locale: Locale = "en";

const [skillsRaw, serversRaw, collectionsRaw, docsRaw, agentsRaw, hooksRaw, commandsRaw, toolsRaw] = await Promise.all([
  getSkills(),
  getServers(),
  getCollections(),
  getDocs(),
  getAgents(),
  getHooks(),
  getCommands(),
  getTools(),
]);

const skills = localizeEntries(skillsRaw, locale);
const servers = localizeEntries(serversRaw, locale);
const collections = localizeEntries(collectionsRaw, locale);
const docs = localizeEntries(docsRaw, locale);
const agents = localizeEntries(agentsRaw, locale);
const hooks = localizeEntries(hooksRaw, locale);
const commands = localizeEntries(commandsRaw, locale);
const tools = localizeEntries(toolsRaw, locale);

const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);

const {
  featuredSkills,
  featuredAgents,
  featuredServers,
  featuredTools,
  featuredHooks,
  workflowEssentials,
} = buildHomepageCuration(
  { skills, agents, servers, tools, hooks },
  base,
  locale,
);

const total = skills.length + agents.length + servers.length + hooks.length + commands.length + tools.length;

const tagCount = new Map<string, number>();
for (const e of [...skills, ...servers, ...agents, ...hooks, ...tools]) {
  for (const tag of e.tags ?? []) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
}
const popularTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---
<Base title={t("home.title", locale)} locale={locale}>
  <section class="hero">
    <div class="hero-shell">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-kicker">{t("home.eyebrow", locale)}</div>
          <h1>{t("home.headline", locale)}</h1>
          <p class="lede">{t("home.lede", locale)}</p>
          <div class="hero-cta">
            <a class="btn btn-primary" href={url("skills/")}>{t("home.ctaBrowse", locale, { count: total })}</a>
            <a class="btn" href="https://github.com/LucasSantana-Dev/ai-dev-toolkit/blob/main/docs/guides/installing.md">{t("home.ctaQuickstart", locale)} ↗</a>
          </div>
          <p class="hero-note">{skills.length} skills, {agents.length} agents, {servers.length} servers, {commands.length} commands, {docs.length} docs.</p>
        </div>

        <aside class="hero-aside">
          <div class="hero-surface hero-install">
            <div class="hero-surface-title">{t("home.commandTitle", locale)}</div>
            <InstallBlock command="npx forge-kit install <slug>" label={t("installCopy.label", locale)} />
            <p>{t("home.commandExample", locale)}</p>
            <p><a href="https://github.com/LucasSantana-Dev/ai-dev-toolkit/blob/main/docs/guides/installing.md">{t("home.commandGuideCta", locale)} →</a></p>
          </div>

          <div class="metric-grid">
            <div class="metric-card"><strong>{total}</strong><span>{t("home.metric.flow", locale)}</span></div>
            <div class="metric-card"><strong>{collections.length}</strong><span>{t("home.metric.collections", locale)}</span></div>
            <div class="metric-card"><strong>6</strong><span>{t("home.metric.depth", locale)}</span></div>
            <div class="metric-card"><strong>1</strong><span>{t("home.metric.install", locale)}</span></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="section-top">
    <div>
      <h2>{t("home.section.collections", locale)}</h2>
      <p class="lead-muted">{t("home.section.collectionsLede", locale)}</p>
    </div>
    <a class="section-link" href={url("collections/")}>{t("home.allOf", locale, { count: collections.length, kind: t("list.collections.title", locale).toLowerCase() })}</a>
  </div>
  <CollectionsFeaturedGrid
    collections={collections}
    locale={locale}
    hrefFor={(id) => url(`collections/${id}/`)}
    heading={t("home.collections.title", locale)}
    lede={t("home.collections.lede", locale)}
  />

  <div class="section-top">
    <div><h2>{t("home.section.skills", locale)}</h2></div>
    <a class="section-link" href={url("skills/")}>{t("home.allOf", locale, { count: skills.length, kind: t("nav.skills", locale).toLowerCase() })}</a>
  </div>
  <div class="grid">
    {featuredSkills.map((s) => (
      <Card kind="skill" id={s.id} name={s.name} description={s.description} tags={s.tags} href={s.href} extraTag={s.extraTag} />
    ))}
  </div>

  <div class="section-top">
    <div><h2>{t("home.section.agents", locale)}</h2></div>
    <a class="section-link" href={url("agents/")}>{t("home.allOf", locale, { count: agents.length, kind: t("nav.agents", locale).toLowerCase() })}</a>
  </div>
  <div class="grid">
    {featuredAgents.map((a) => (
      <Card kind="agent" id={a.id} name={a.name} description={a.description} tags={a.tags} href={a.href} extraTag={a.extraTag} />
    ))}
  </div>

  <div class="section-top">
    <div><h2>{t("home.section.servers", locale)}</h2></div>
    <a class="section-link" href={url("servers/")}>{t("home.allOf", locale, { count: servers.length, kind: t("nav.servers", locale).toLowerCase() })}</a>
  </div>
  <div class="grid">
    {featuredServers.map((s) => (
      <Card kind="server" id={s.id} name={s.name} description={s.description} tags={s.tags} href={s.href} extraTag={s.extraTag} />
    ))}
  </div>

  <div class="section-top">
    <div>
      <h2>{t("home.section.tools", locale)}</h2>
      <p class="lead-muted">{t("home.section.toolsLede", locale)}</p>
    </div>
    <a class="section-link" href={url("tools/")}>{t("home.allOf", locale, { count: tools.length, kind: t("nav.tools", locale).toLowerCase() })}</a>
  </div>
  <div class="grid">
    {featuredTools.map((tool) => (
      <Card kind="tool" id={tool.id} name={tool.name} description={tool.description} tags={tool.tags} href={tool.href} extraTag={tool.extraTag} />
    ))}
  </div>

  <div class="section-top">
    <div><h2>{t("home.section.hooks", locale)}</h2></div>
    <a class="section-link" href={url("hooks/")}>{t("home.allOf", locale, { count: hooks.length, kind: t("nav.hooks", locale).toLowerCase() })}</a>
  </div>
  <div class="grid">
    {featuredHooks.map((h) => (
      <Card kind="hook" id={h.id} name={h.name} description={h.description} tags={h.tags} href={h.href} extraTag={h.extraTag} />
    ))}
  </div>

  <div class="section-top">
    <div>
      <h2>{t("home.section.workflow", locale)}</h2>
      <p class="lead-muted">{t("home.section.workflowLede", locale)}</p>
    </div>
    <a class="section-link" href={url("search/")}>{t("home.workflow.exploreAll", locale)}</a>
  </div>
  <div class="workflow-grid">
    {workflowEssentials.map((item) => (
      <section class="hero-surface workflow-card">
        <header class="workflow-card-header">
          <h3>{t(`home.workflow.${item.key}.title`, locale)}</h3>
          <p class="lead-muted">{t(`home.workflow.${item.key}.lede`, locale)}</p>
        </header>
        {item.primary ? (
          <Card
            kind={item.primary.kind}
            id={item.primary.id}
            name={displayEntryName(item.primary.name)}
            description={item.primary.description}
            tags={item.related.slice(0, 4).map((entry) => displayEntryName(entry.name))}
            href={item.primary.href}
            extraTag={item.primary.kind}
          />
        ) : (
          <a class="section-link" href={item.browseHref}>{t("home.workflow.fallback", locale)}</a>
        )}
        {item.related.length > 0 && (
          <div class="chips">
            {item.related.map((entry) => (
              <a class="chip" href={entry.href}>{displayEntryName(entry.name)}</a>
            ))}
          </div>
        )}
        <a class="section-link workflow-card-footer" href={item.browseHref}>{t("home.workflow.browse", locale)} →</a>
      </section>
    ))}
  </div>

  <div class="section-top">
    <div><h2>{t("home.section.tags", locale)}</h2></div>
  </div>
  <div class="chips">
    {popularTags.map((tag) => (
      <a href={url(`search/?tag=${encodeURIComponent(tag)}`)} class="chip">#{tag}</a>
    ))}
  </div>
</Base>
