---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CollectionsFeaturedGrid from "../components/CollectionsFeaturedGrid.astro";
import HeroTerminal from "../components/HeroTerminal.astro";
import {
  getSkills,
  getServers,
  getCollections,
  getDocs,
  getTutorials,
  getAgents,
  getHooks,
  getCommands,
  getTools,
} from "../lib/catalog.ts";
import { localizeEntries, t, localizedUrl, type Locale } from "../lib/i18n.ts";

const locale: Locale = "en";

const [skillsRaw, serversRaw, collectionsRaw, docsRaw, tutorialsRaw, agentsRaw, hooksRaw, commandsRaw, toolsRaw] = await Promise.all([
  getSkills(),
  getServers(),
  getCollections(),
  getDocs(),
  getTutorials(),
  getAgents(),
  getHooks(),
  getCommands(),
  getTools(),
]);

const skills = localizeEntries(skillsRaw, locale);
const servers = localizeEntries(serversRaw, locale);
const collections = localizeEntries(collectionsRaw, locale);
const docs = localizeEntries(docsRaw, locale);
const tutorials = localizeEntries(tutorialsRaw, locale);
const agents = localizeEntries(agentsRaw, locale);
const hooks = localizeEntries(hooksRaw, locale);
const commands = localizeEntries(commandsRaw, locale);
const tools = localizeEntries(toolsRaw, locale);

const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);

const total = skills.length + agents.length + servers.length + hooks.length + commands.length + tools.length + tutorials.length + docs.length;

const tagCount = new Map<string, number>();
for (const e of [...skills, ...servers, ...agents, ...hooks, ...tools]) {
  for (const tag of e.tags ?? []) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
}
const popularTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---
<Base title={t("home.title", locale)} locale={locale}>
  <section class="hero">
    <div class="hero-shell">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-kicker">{t("home.eyebrow", locale)}</div>
          <h1>{t("home.headline", locale)}</h1>
          <p class="lede">{t("home.lede", locale)}</p>
          <div class="hero-cta">
            <a class="btn btn-primary" href={url("skills/")}>{t("home.ctaBrowse", locale, { count: total })}</a>
            <a class="btn" href="https://github.com/LucasSantana-Dev/forgekit/blob/main/docs/guides/installing.md">{t("home.ctaQuickstart", locale)} ↗</a>
          </div>
        </div>

        <div class="hero-aside">
          <div class="hero-install">
            <div class="hero-surface-title">{t("home.commandTitle", locale)}</div>
            <HeroTerminal command="npx forge-kit install <slug>" locale={locale} />
            <p>{t("home.commandExample", locale)}</p>
            <p><a href="https://github.com/LucasSantana-Dev/forgekit/blob/main/docs/guides/installing.md">{t("home.commandGuideCta", locale)} →</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="home-search-wrap">
    <div class="home-search-inner">
      <span class="home-search-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
          <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
          <path d="M14 14L18 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </span>
      <input
        id="home-search"
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder={`Search ${total} skills, agents, servers, tools…`}
        aria-label="Search the catalog"
        class="home-search-input"
      />
    </div>
  </div>
  <script is:inline define:vars={{ searchBase: url("search/") }}>
    (function () {
      const input = document.getElementById("home-search");
      if (!input) return;
      input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          const q = input.value.trim();
          if (q) window.location.href = searchBase + "?q=" + encodeURIComponent(q);
        }
      });
    })();
  </script>

  <div class="section-top">
    <div>
      <h2>{t("home.section.collections", locale)}</h2>
      <p class="lead-muted">{t("home.section.collectionsLede", locale)}</p>
    </div>
    <a class="section-link" href={url("collections/")}>{t("home.allOf", locale, { count: collections.length, kind: t("list.collections.title", locale).toLowerCase() })}</a>
  </div>
  <CollectionsFeaturedGrid
    collections={collections.slice(0, 6)}
    locale={locale}
    hrefFor={(id) => url(`collections/${id}/`)}
  />

  <div class="section-top">
    <div><h2>{t("home.section.tags", locale)}</h2></div>
  </div>
  <div class="chips">
    {popularTags.map((tag) => (
      <a href={url(`search/?tag=${encodeURIComponent(tag)}`)} class="chip">#{tag}</a>
    ))}
  </div>

</Base>

<style>
  .home-search-wrap {
    margin: 2.5rem 0 2rem;
  }
  .home-search-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .home-search-icon {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg-subtle);
    pointer-events: none;
    display: flex;
    align-items: center;
  }
  .home-search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 1.1rem 1.4rem 1.1rem 3.4rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--fg);
    font-size: 1.1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
    appearance: none;
  }
  .home-search-input::placeholder {
    color: var(--fg-subtle);
  }
  .home-search-input:focus {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 20%, transparent);
  }
  .home-search-input::-webkit-search-cancel-button {
    display: none;
  }

</style>
