---
import Base from "../../../layouts/Base.astro";
import { getDocs } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { kindGlyph, kindLabel, renderMarkdown } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const docs = localizeEntries(await getDocs(), locale);
  return docs.map((doc) => ({ params: { id: doc.id }, props: { doc } }));
}

const { doc } = Astro.props;
const rendered = renderMarkdown(doc.body);
---
<Base title={doc.title} description={doc.description} locale={locale}>
  <p style="margin-bottom: 1.5rem;"><a href="../">← toda a documentação</a></p>
  <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem;">
    <span style="font-size: 1.6rem;">{kindGlyph(doc.kind)}</span>
    <h1 style="margin: 0;">{doc.title}</h1>
    <span class="kind kind-doc">{kindLabel(doc.kind)}</span>
  </div>
  <p class="lead-muted" style="margin-bottom: 1rem;">{doc.description}</p>
  <div class="tags" style="margin-bottom: 1.5rem;">
    {doc.tags.map((t) => <span class="tag">{t}</span>)}
  </div>

  <article class="markdown" set:html={rendered} />

  {doc.source?.path && (
    <p style="color: var(--fg-subtle); font-size: 0.82rem; margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1rem;">
      Fonte: <code>{doc.source.path}</code>
      {doc.source.license && <> · {doc.source.license}</>}
    </p>
  )}
</Base>
