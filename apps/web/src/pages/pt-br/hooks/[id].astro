---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import UsageBlock from "../../../components/UsageBlock.astro";
import { getHooks } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const hooks = localizeEntries(await getHooks(), locale);
  return hooks.map((hook) => ({ params: { id: hook.id }, props: { hook } }));
}

const { hook } = Astro.props;
const cmd = installCommand("hook", hook.id)!;
---
<Base title={hook.name} description={hook.description} locale={locale}>
  <EntryHeader kind="hook" name={hook.name} description={hook.description} backLabel="Todos os hooks">
    <div class="entry-tags">
      <span class="tag">event: {hook.event}</span>
      <span class="tag">runtime: {hook.runtime}</span>
      {hook.matcher && <span class="tag">matcher: {hook.matcher}</span>}
      {hook.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={hook.usage} locale={locale} />

  <h2>Script</h2>
  <pre><code>{hook.script}</code></pre>

  {(hook.source?.path || hook.license) && (
    <p class="entry-source">
      {hook.source?.path && <>Fonte: <code>{hook.source.path}</code></>}
      {hook.license && <>{hook.source?.path ? " · " : "Licença: "}{hook.license}</>}
    </p>
  )}
</Base>
