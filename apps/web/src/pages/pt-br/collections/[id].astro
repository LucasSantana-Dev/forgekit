---
import Base from "../../../layouts/Base.astro";
import Card from "../../../components/Card.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import {
  buildCollectionItemResolver,
  collectionItemPath,
  getCatalogData,
  getCollections,
} from "../../../lib/catalog.ts";
import { localizeEntries, localizedUrl, type Locale } from "../../../lib/i18n.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const staticLocale: Locale = "pt-br";
  const collections = localizeEntries(await getCollections(), staticLocale);
  return collections.map((collection) => ({ params: { id: collection.id }, props: { collection } }));
}

const catalog = await getCatalogData();
const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);

const localizedCatalog = {
  skills: localizeEntries(catalog.skills, locale),
  servers: localizeEntries(catalog.servers, locale),
  docs: localizeEntries(catalog.docs, locale),
  agents: localizeEntries(catalog.agents, locale),
  hooks: localizeEntries(catalog.hooks, locale),
  commands: localizeEntries(catalog.commands, locale),
  tools: localizeEntries(catalog.tools, locale),
};

const resolveItem = buildCollectionItemResolver(localizedCatalog, (item) => url(collectionItemPath(item)));
---
<Base title={collection.name} description={collection.description} locale={locale}>
  <EntryHeader kind="collection" name={collection.name} description={collection.description} backLabel="Todas as coleções">
    {collection.tags && collection.tags.length > 0 && (
      <div class="entry-tags">
        {collection.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </EntryHeader>

  <h2>Itens ({collection.items.length})</h2>
  <div class="grid">
    {collection.items.map((item) => <Card {...resolveItem(item)} />)}
  </div>
</Base>
