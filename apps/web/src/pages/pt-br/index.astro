---
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import InstallBlock from "../../components/InstallBlock.astro";
import {
  getSkills,
  getServers,
  getCollections,
  getDocs,
  getAgents,
  getHooks,
  getCommands,
  getTools,
} from "../../lib/catalog.ts";
import { localizeEntries, t, localizedUrl, type Locale } from "../../lib/i18n.ts";

const locale: Locale = "pt-br";

const [skillsRaw, serversRaw, collectionsRaw, docsRaw, agentsRaw, hooksRaw, commandsRaw, toolsRaw] = await Promise.all([
  getSkills(),
  getServers(),
  getCollections(),
  getDocs(),
  getAgents(),
  getHooks(),
  getCommands(),
  getTools(),
]);

const skills = localizeEntries(skillsRaw, locale);
const servers = localizeEntries(serversRaw, locale);
const collections = localizeEntries(collectionsRaw, locale);
const docs = localizeEntries(docsRaw, locale);
const agents = localizeEntries(agentsRaw, locale);
const hooks = localizeEntries(hooksRaw, locale);
const commands = localizeEntries(commandsRaw, locale);
const tools = localizeEntries(toolsRaw, locale);

const base = import.meta.env.BASE_URL;
const url = (p: string) => localizedUrl(base, p, locale);

const featuredSkills = skills.slice(0, 3);
const featuredAgents = agents.slice(0, 3);
const featuredServers = servers.slice(0, 3);
const featuredTools = tools.slice(0, 3);
const featuredHooks = hooks.slice(0, 3);

const total = skills.length + agents.length + servers.length + hooks.length + commands.length + tools.length;

const tagCount = new Map<string, number>();
for (const e of [...skills, ...servers, ...agents, ...hooks, ...tools]) {
  for (const tag of e.tags ?? []) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
}
const popularTags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---
<Base title={t("home.title", locale)} locale={locale}>
  <section class="hero">
    <div class="hero-content">
      <h1>{t("home.headline", locale)}</h1>
      <p class="lede">{t("home.lede", locale)}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={url("skills/")}>{t("home.ctaBrowse", locale, { count: total })}</a>
        <a class="btn" href="https://github.com/LucasSantana-Dev/ai-dev-toolkit/blob/main/packages/catalog/docs/QUICKSTART.md">{t("home.ctaQuickstart", locale)} ↗</a>
      </div>
      <div style="max-width: 560px; margin: 2rem auto 0;">
        <InstallBlock command="npx forge-kit setup --all" label={t("installCopy.label", locale)} />
      </div>
    </div>
  </section>

  <div class="stats">
    <div class="stat"><span class="stat-value">{skills.length}</span><span class="stat-label">{t("home.stat.skills", locale)}</span></div>
    <div class="stat"><span class="stat-value">{agents.length}</span><span class="stat-label">{t("home.stat.agents", locale)}</span></div>
    <div class="stat"><span class="stat-value">{servers.length}</span><span class="stat-label">{t("home.stat.servers", locale)}</span></div>
    <div class="stat"><span class="stat-value">{tools.length}</span><span class="stat-label">{t("home.stat.tools", locale)}</span></div>
    <div class="stat"><span class="stat-value">{hooks.length}</span><span class="stat-label">{t("home.stat.hooks", locale)}</span></div>
    <div class="stat"><span class="stat-value">{commands.length}</span><span class="stat-label">{t("home.stat.commands", locale)}</span></div>
    <div class="stat"><span class="stat-value">{docs.length}</span><span class="stat-label">{t("home.stat.docs", locale)}</span></div>
  </div>

  <h2>{t("home.section.collections", locale)}</h2>
  <p class="lead-muted">{t("home.section.collectionsLede", locale)}</p>
  <div class="grid">
    {collections.map((c) => (
      <Card
        kind="collection"
        id={c.id}
        name={c.name}
        description={c.description}
        tags={c.tags ?? []}
        href={url(`collections/${c.id}/`)}
        extraTag={`${c.items.length} items`}
      />
    ))}
  </div>

  <h2>{t("home.section.skills", locale)}</h2>
  <div class="grid">
    {featuredSkills.map((s) => (
      <Card kind="skill" id={s.id} name={s.name} description={s.description} tags={s.tags} href={url(`skills/${s.id}/`)} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={url("skills/")}>{t("home.allOf", locale, { count: skills.length, kind: t("nav.skills", locale).toLowerCase() })}</a></p>

  <h2>{t("home.section.agents", locale)}</h2>
  <div class="grid">
    {featuredAgents.map((a) => (
      <Card kind="agent" id={a.id} name={a.name} description={a.description} tags={a.tags} href={url(`agents/${a.id}/`)} extraTag={a.model} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={url("agents/")}>{t("home.allOf", locale, { count: agents.length, kind: t("nav.agents", locale).toLowerCase() })}</a></p>

  <h2>{t("home.section.servers", locale)}</h2>
  <div class="grid">
    {featuredServers.map((s) => (
      <Card kind="server" id={s.id} name={s.name} description={s.description} tags={s.tags} href={url(`servers/${s.id}/`)} extraTag={s.transport} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={url("servers/")}>{t("home.allOf", locale, { count: servers.length, kind: t("nav.servers", locale).toLowerCase() })}</a></p>

  <h2>{t("home.section.tools", locale)}</h2>
  <p class="lead-muted">{t("home.section.toolsLede", locale)}</p>
  <div class="grid">
    {featuredTools.map((tool) => (
      <Card kind="tool" id={tool.id} name={tool.name} description={tool.description} tags={tool.tags} href={url(`tools/${tool.id}/`)} extraTag={`${tool.category} · ${tool.runtime}`} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={url("tools/")}>{t("home.allOf", locale, { count: tools.length, kind: t("nav.tools", locale).toLowerCase() })}</a></p>

  <h2>{t("home.section.hooks", locale)}</h2>
  <div class="grid">
    {featuredHooks.map((h) => (
      <Card kind="hook" id={h.id} name={h.name} description={h.description} tags={h.tags} href={url(`hooks/${h.id}/`)} extraTag={h.event} />
    ))}
  </div>
  <p style="margin-top: 1rem;"><a href={url("hooks/")}>{t("home.allOf", locale, { count: hooks.length, kind: t("nav.hooks", locale).toLowerCase() })}</a></p>

  <h2>{t("home.section.tags", locale)}</h2>
  <div class="chips">
    {popularTags.map((tag) => (
      <a href={url(`search/?tag=${encodeURIComponent(tag)}`)} class="chip">#{tag}</a>
    ))}
  </div>
</Base>
