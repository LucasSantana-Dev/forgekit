---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import UsageBlock from "../../../components/UsageBlock.astro";
import { getTools } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const tools = localizeEntries(await getTools(), locale);
  return tools.map((tool) => ({ params: { id: tool.id }, props: { tool } }));
}

const { tool } = Astro.props;
const cmd = installCommand("tool", tool.id)!;
---
<Base title={tool.name} description={tool.description} locale={locale}>
  <EntryHeader kind="tool" name={tool.name} description={tool.description} backLabel="Todas as ferramentas">
    <div class="entry-tags">
      <span class="tag">runtime: {tool.runtime}</span>
      <span class="tag">category: {tool.category}</span>
      {tool.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={tool.usage} locale={locale} />

  {tool.install?.dependencies && tool.install.dependencies.length > 0 && (
    <>
      <h2>Dependências</h2>
      <ul class="markdown">
        {tool.install.dependencies.map((d) => <li><code>{d}</code></li>)}
      </ul>
    </>
  )}

  <h2>Script</h2>
  <pre><code>{tool.script}</code></pre>

  {(tool.source?.path || tool.license) && (
    <p class="entry-source">
      {tool.source?.path && <>Fonte: <code>{tool.source.path}</code></>}
      {tool.license && <>{tool.source?.path ? " · " : "Licença: "}{tool.license}</>}
    </p>
  )}
</Base>
