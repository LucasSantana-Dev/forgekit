---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import UsageBlock from "../../../components/UsageBlock.astro";
import { getAgents } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand, renderMarkdown } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const agents = localizeEntries(await getAgents(), locale);
  return agents.map((agent) => ({ params: { id: agent.id }, props: { agent } }));
}

const { agent } = Astro.props;
const rendered = renderMarkdown(agent.body);
const cmd = installCommand("agent", agent.id)!;
---
<Base title={agent.name} description={agent.description} locale={locale}>
  <EntryHeader kind="agent" name={agent.name} description={agent.description} backLabel="Todos os agentes">
    <div class="entry-tags">
      {agent.model && <span class="tag">{agent.model}</span>}
      {agent.level !== undefined && <span class="tag">level {agent.level}</span>}
      {agent.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={agent.usage} locale={locale} />

  {agent.disallowed_tools && agent.disallowed_tools.length > 0 && (
    <>
      <h2>Ferramentas bloqueadas</h2>
      <p class="lead-muted">Este agente não pode chamar:</p>
      <ul class="markdown">
        {agent.disallowed_tools.map((t) => <li><code>{t}</code></li>)}
      </ul>
    </>
  )}

  <h2>Prompt do sistema</h2>
  <article class="markdown" set:html={rendered} />

  {agent.source?.path && (
    <p class="entry-source">
      Fonte: <code>{agent.source.path}</code>
      {agent.license && <> · {agent.license}</>}
    </p>
  )}
</Base>
