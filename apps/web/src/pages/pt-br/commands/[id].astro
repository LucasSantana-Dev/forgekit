---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import { getCommands } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand, renderMarkdown } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const commands = localizeEntries(await getCommands(), locale);
  return commands.map((command) => ({ params: { id: command.id }, props: { command } }));
}

const { command } = Astro.props;
const rendered = renderMarkdown(command.body);
const cmd = installCommand("command", command.id)!;
---
<Base title={command.name} description={command.description} locale={locale}>
  <EntryHeader kind="command" name={command.name} description={command.description} backLabel="Todos os comandos">
    <div class="entry-tags">
      {command.category && <span class="tag">{command.category}</span>}
      {command.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <article class="markdown mt-4" set:html={rendered} />

  {(command.source?.path || command.license) && (
    <p class="entry-source">
      {command.source?.path && <>Fonte: <code>{command.source.path}</code></>}
      {command.license && <>{command.source?.path ? " · " : "Licença: "}{command.license}</>}
    </p>
  )}
</Base>
