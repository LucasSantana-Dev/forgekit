---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import UsageBlock from "../../../components/UsageBlock.astro";
import { getSkills } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand, renderMarkdown } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const skills = localizeEntries(await getSkills(), locale);
  return skills.map((skill) => ({ params: { id: skill.id }, props: { skill } }));
}

const { skill } = Astro.props;
const rendered = renderMarkdown(skill.body);
const cmd = installCommand("skill", skill.id)!;
---
<Base title={skill.name} description={skill.description} locale={locale}>
  <EntryHeader kind="skill" name={skill.name} description={skill.description} backLabel="Todas as skills">
    <div class="entry-tags">
      {skill.version && <span class="tag">v{skill.version}</span>}
      {skill.editors?.map((e) => <span class="tag">{e}</span>)}
      {skill.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={skill.usage} locale={locale} />

  <article class="markdown mt-4" set:html={rendered} />

  {(skill.source?.path || skill.license) && (
    <p class="entry-source">
      {skill.source?.path && <>Fonte: <code>{skill.source.path}</code></>}
      {skill.license && <>{skill.source?.path ? " · " : "Licença: "}{skill.license}</>}
    </p>
  )}
</Base>
