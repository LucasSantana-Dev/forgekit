---
import Base from "../../../layouts/Base.astro";
import EntryHeader from "../../../components/EntryHeader.astro";
import InstallBlock from "../../../components/InstallBlock.astro";
import UsageBlock from "../../../components/UsageBlock.astro";
import { getServers } from "../../../lib/catalog.ts";
import { localizeEntries, type Locale } from "../../../lib/i18n.ts";
import { installCommand } from "../../../lib/ui.ts";

const locale: Locale = "pt-br";

export async function getStaticPaths() {
  const locale: Locale = "pt-br";
  const servers = localizeEntries(await getServers(), locale);
  return servers.map((server) => ({ params: { id: server.id }, props: { server } }));
}

const { server } = Astro.props;

const cmd = installCommand("server", server.id)!;
const runCmd =
  server.transport === "stdio"
    ? `${server.command ?? ""} ${(server.args ?? []).join(" ")}`.trim()
    : server.url ?? "";
---
<Base title={server.name} description={server.description} locale={locale}>
  <EntryHeader kind="server" name={server.name} description={server.description} backLabel="Todos os servidores">
    <div class="entry-tags">
      <span class="tag">transport: {server.transport}</span>
      {server.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <InstallBlock command={cmd} />

  <UsageBlock usage={server.usage} locale={locale} />

  <h2>Como ele roda</h2>
  <pre><code>{runCmd}</code></pre>

  {server.env && server.env.length > 0 && (
    <>
      <h2>Variáveis de ambiente</h2>
      <ul class="markdown">
        {server.env.map((e) => (
          <li>
            <code>{e.name}</code>
            {e.required ? " (obrigatória)" : " (opcional)"}
            {e.description && <> — {e.description}</>}
          </li>
        ))}
      </ul>
    </>
  )}

  <p class="entry-source">
    {server.homepage && <>Homepage: <a href={server.homepage}>{server.homepage}</a></>}
    {server.license && <> · {server.license}</>}
  </p>
</Base>
