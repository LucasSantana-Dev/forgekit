---
import Base from "../../layouts/Base.astro";
import EntryHeader from "../../components/EntryHeader.astro";
import RelatedCollections from "../../components/RelatedCollections.astro";
import RelatedTutorials from "../../components/RelatedTutorials.astro";
import { getDocs, getTutorials, getCollections } from "../../lib/catalog.ts";
import { renderMarkdown } from "../../lib/ui.ts";

export async function getStaticPaths() {
  const docs = await getDocs();
  return docs.map((d) => ({ params: { id: d.id }, props: { doc: d } }));
}
const { doc } = Astro.props;
const rendered = renderMarkdown(doc.body);
const [tutorials, collections] = await Promise.all([getTutorials(), getCollections()]);
const base = import.meta.env.BASE_URL;
---
<Base title={doc.title} description={doc.description}>
  <EntryHeader kind="doc" name={doc.title} description={doc.description} backLabel="All docs">
    <div class="entry-tags">
      {doc.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  </EntryHeader>

  <article class="markdown" set:html={rendered} />

  {doc.source?.path && (
    <p class="entry-source">
      Source: <code>{doc.source.path}</code>
      {doc.source.license && <> · {doc.source.license}</>}
    </p>
  )}

  <RelatedCollections kind="doc" id={doc.id} collections={collections} base={base} />
  <RelatedTutorials kind="doc" id={doc.id} tutorials={tutorials} base={base} />
</Base>
