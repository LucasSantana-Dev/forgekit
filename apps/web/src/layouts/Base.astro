---
import type { Locale } from "../lib/i18n";
import { resolveLocale, switchLocalePath, t } from "../lib/i18n";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  noindex?: boolean;
}
const {
  title,
  description = "Curated Forge Kit catalog of Skills, MCP servers, and Claude Code sub-agents for AI-assisted development.",
  locale = resolveLocale(Astro.url.pathname),
  ogImage,
  noindex = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString().replace(/\/$/, "") ?? "";
const localeBase = locale === "en" ? base : `${base}pt-br/`;
const htmlLang = locale === "pt-br" ? "pt-BR" : "en";
const ogLocale = locale === "pt-br" ? "pt_BR" : "en_US";
const ogLocaleAlternate = locale === "pt-br" ? "en_US" : "pt_BR";

const pathname = Astro.url.pathname;
const canonicalPath = pathname.endsWith("/") || pathname.includes(".") ? pathname : `${pathname}/`;
const canonicalUrl = `${site}${canonicalPath}`;
const alternateEn = `${site}${switchLocalePath(canonicalPath, "en")}`;
const alternatePt = `${site}${switchLocalePath(canonicalPath, "pt-br")}`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${site}${ogImage.startsWith("/") ? ogImage : `/${ogImage}`}`)
  : `${site}/og-image.svg`;
const fullTitle = `${title} · Forge Kit`;

const currentPath = pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: `${localeBase}skills/`, key: "nav.skills" },
  { href: `${localeBase}agents/`, key: "nav.agents" },
  { href: `${localeBase}servers/`, key: "nav.servers" },
  { href: `${localeBase}tools/`, key: "nav.tools" },
  { href: `${localeBase}hooks/`, key: "nav.hooks" },
  { href: `${localeBase}collections/`, key: "nav.collections" },
  { href: `${localeBase}commands/`, key: "nav.commands" },
  { href: `${localeBase}docs/`, key: "nav.docs" },
];
const isActive = (href: string) => {
  const trimmed = href.replace(/\/$/, "") || "/";
  return currentPath === trimmed || currentPath.startsWith(`${trimmed}/`);
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Forge Kit",
  alternateName: "forge-kit",
  description,
  url: site || canonicalUrl,
  inLanguage: htmlLang,
  publisher: {
    "@type": "Person",
    name: "Lucas Santana",
    url: "https://github.com/LucasSantana-Dev",
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${site}${localeBase}search/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#050505" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="pt-BR" href={alternatePt} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    <meta property="og:site_name" content="Forge Kit" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style is:global>
      :root {
        --bg: #050505;
        --bg-elev: #0a0a0a;
        --bg-panel: #0f0f10;
        --bg-hover: #151517;
        --fg: #f5f5f5;
        --fg-muted: #a1a1aa;
        --fg-subtle: #71717a;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --accent: #d4d4d8;
        --accent-hot: #ffffff;
        --accent-soft: rgba(255, 255, 255, 0.06);
        --code-bg: rgba(255, 255, 255, 0.035);
        --chip-bg: rgba(255, 255, 255, 0.05);
        --chip-fg: #e4e4e7;

        --kind-skill:      oklch(75% 0.08 75);
        --kind-agent:      oklch(72% 0.10 275);
        --kind-server:     oklch(73% 0.09 185);
        --kind-collection: oklch(71% 0.10 15);
        --kind-doc:        oklch(70% 0.09 235);
        --kind-hook:       oklch(73% 0.11 45);
        --kind-command:    oklch(85% 0.015 85);
        --kind-tool:       oklch(72% 0.09 145);

        --radius: 14px;
        --radius-sm: 10px;
        --radius-lg: 22px;
        --shadow-card: 0 18px 38px rgba(0, 0, 0, 0.28);

        font-family: "Geist", "Inter", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-feature-settings: "cv11", "ss01", "ss03";
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }

      :focus-visible {
        outline: 2px solid var(--accent-hot);
        outline-offset: 3px;
        border-radius: 6px;
      }

      .skip-link {
        position: absolute;
        top: 0;
        left: 0;
        padding: 0.65rem 1rem;
        background: var(--fg);
        color: #050505;
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 0 0 8px 0;
        transform: translateY(-110%);
        transition: transform 0.18s ease;
        z-index: 100;
      }
      .skip-link:focus-visible {
        transform: translateY(0);
        color: #050505;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 26%),
          radial-gradient(circle at 85% 0%, rgba(255, 255, 255, 0.03), transparent 18%),
          linear-gradient(180deg, #040404 0%, #070707 100%);
        color: var(--fg);
        line-height: 1.6;
        font-size: 15px;
        -webkit-font-smoothing: antialiased;
        position: relative;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(rgba(255,255,255,0.015), rgba(255,255,255,0.015)),
          radial-gradient(circle at 50% 0%, rgba(255,255,255,0.035), transparent 28%);
        opacity: 0.4;
      }
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0.032;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hot); }

      header.site {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(5, 5, 5, 0.84);
        backdrop-filter: blur(18px) saturate(120%);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.16);
      }
      .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        color: var(--fg);
        font-weight: 650;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .brand:hover { color: var(--fg); }
      .brand-mark {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        display: block;
        object-fit: contain;
        padding: 5px;
      }
      nav.primary {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        margin-left: auto;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      nav.primary a {
        color: var(--fg-muted);
        padding: 0.42rem 0.72rem;
        border-radius: 10px;
        font-size: 0.88rem;
        border: 1px solid transparent;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease, transform 0.16s ease;
      }
      nav.primary a:hover {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--border);
        transform: translateY(-1px);
      }
      nav.primary a.github {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.08);
      }
      nav.primary a.collections {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.12);
        color: var(--fg);
      }
      nav.primary a.collections:hover {
        background: rgba(255, 255, 255, 0.08);
      }
      nav.primary a[aria-current="page"],
      nav.primary a.is-active {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.18);
      }

      main:focus-visible {
        outline: none;
      }

      .workflow-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
        gap: 1rem;
      }
      .workflow-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.25rem;
      }
      .workflow-card-header h3 {
        margin: 0 0 0.4rem;
        font-size: 1.05rem;
        line-height: 1.25;
      }
      .workflow-card-header p {
        margin: 0;
        font-size: 0.92rem;
        line-height: 1.55;
        max-width: 52ch;
      }
      .workflow-card-footer {
        margin-top: auto;
        align-self: flex-start;
        font-size: 0.85rem;
      }
      @media (max-width: 720px) {
        .workflow-grid {
          grid-template-columns: 1fr;
        }
      }

      main {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1.75rem 1.25rem 4rem;
      }
      h1, h2, h3, h4 { color: var(--fg); letter-spacing: -0.04em; }
      h1 {
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        line-height: 1.05;
        margin: 0;
        font-weight: 720;
      }
      h2 {
        font-size: clamp(1.1rem, 2vw, 1.45rem);
        margin: 0;
        font-weight: 700;
      }
      h3 { font-size: 1.04rem; margin: 0; font-weight: 650; }
      p { color: var(--fg-muted); margin: 0.5rem 0; }

      .hero {
        padding: 0.5rem 0 1.25rem;
        margin-bottom: 1.75rem;
      }
      .hero-shell {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: clamp(18px, 2.5vw, 26px);
        background:
          radial-gradient(ellipse at 8% 95%, oklch(75% 0.08 75 / 0.07), transparent 42%),
          linear-gradient(180deg, rgba(18, 18, 20, 0.96), rgba(10, 10, 11, 0.98)),
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.04), transparent 30%),
          radial-gradient(circle at 80% 10%, rgba(255, 255, 255, 0.03), transparent 24%);
        box-shadow: var(--shadow-card);
      }
      .hero-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.012) 48%, transparent 100%),
          radial-gradient(circle at 18% 18%, rgba(255,255,255,0.03), transparent 12%);
        pointer-events: none;
      }
      .hero-grid {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(290px, 0.9fr);
        gap: clamp(1.25rem, 3vw, 2rem);
        padding: clamp(1.15rem, 2.8vw, 1.7rem);
        align-items: stretch;
      }
      .hero-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
        min-width: 0;
      }
      .hero-kicker {
        display: inline-flex;
        align-self: flex-start;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.7rem;
        border-radius: 999px;
        border: 1px solid oklch(75% 0.08 75 / 0.28);
        background: oklch(75% 0.08 75 / 0.07);
        color: var(--kind-skill);
        font-size: 0.74rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .hero h1 {
        font-size: clamp(2.9rem, 6vw, 5.4rem);
        line-height: 0.92;
        color: var(--fg);
        max-width: 11ch;
      }
      .hero p.lede {
        max-width: 72ch;
        font-size: 1.08rem;
        line-height: 1.7;
        color: var(--fg-muted);
      }
      .hero-cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.72rem 1.05rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255, 255, 255, 0.03);
        color: var(--fg);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
      }
      .btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255,255,255,0.16);
        color: var(--fg);
      }
      .btn:active { transform: translateY(0); }
      .btn-primary {
        background: linear-gradient(180deg, oklch(99% 0.003 265) 0%, oklch(92% 0.004 265) 100%);
        border-color: oklch(95% 0.003 265 / 0.8);
        color: oklch(5% 0.003 265);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.18);
      }
      .btn-primary:hover { color: oklch(5% 0.003 265); background: linear-gradient(180deg, oklch(99% 0.003 265) 0%, oklch(96% 0.003 265) 100%); }
      .hero-note {
        font-size: 0.82rem;
        letter-spacing: 0.01em;
        color: var(--fg-subtle);
      }

      .hero-aside {
        display: grid;
        gap: 0.9rem;
        align-content: stretch;
      }
      .hero-surface,
      .search-panel,
      .install {
        backdrop-filter: blur(18px) saturate(145%);
      }
      .hero-surface {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        background: rgba(255,255,255,0.02);
        padding: 1rem;
      }
      .hero-surface-title,
      .search-panel .search-label,
      .install-label {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-bottom: 0.8rem;
        color: var(--fg-subtle);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .hero-surface-title::before,
      .search-panel .search-label::before,
      .install-label::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--kind-skill);
        box-shadow: 0 0 0 4px oklch(75% 0.08 75 / 0.14);
      }
      .hero-install {
        border-radius: 18px;
        background: oklch(75% 0.08 75 / 0.03);
        border: 1px solid oklch(75% 0.08 75 / 0.14);
        padding: 1rem;
        box-shadow: inset 0 1px 0 oklch(75% 0.08 75 / 0.05);
      }
      .hero-install p {
        color: var(--fg-muted);
        font-size: 0.92rem;
        margin-top: 0.65rem;
      }
      .kind-legend {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.5rem;
      }
      .kind-legend-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.8rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.02);
        color: var(--fg-muted);
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
        text-decoration: none;
      }
      .kind-legend-item:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.12);
        color: var(--fg);
      }
      .kind-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: var(--dot-color, var(--fg-subtle));
      }
      .kind-legend-count {
        margin-left: auto;
        font-size: 0.75rem;
        color: var(--fg-subtle);
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .section-top {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin: 2.2rem 0 1rem;
      }
      .section-top h2 + p { max-width: 62ch; }
      .section-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.58rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: var(--fg);
        font-size: 0.88rem;
        font-weight: 600;
        white-space: nowrap;
      }
      .section-link:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.16);
        background: rgba(255,255,255,0.06);
      }

      .search-panel {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        background: rgba(255,255,255,0.02);
        padding: 1rem;
        box-shadow: var(--shadow-card);
        margin: 0 0 1.25rem;
      }
      .search-wrap {
        margin: 0;
        position: relative;
      }
      .search-wrap input {
        width: 100%;
        padding: 0.95rem 1rem 0.95rem 2.75rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        color: var(--fg);
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
      }
      .search-wrap input:focus {
        outline: none;
        border-color: rgba(255,255,255,0.22);
        box-shadow: 0 0 0 4px rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
      }
      .search-wrap .search-icon {
        position: absolute;
        left: 0.95rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg-subtle);
        pointer-events: none;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 0.85rem;
        margin: 2rem 0 3rem;
      }
      .stat {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
        padding: 0.95rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .stat-value {
        font-size: 1.75rem;
        font-weight: 760;
        color: var(--fg);
        letter-spacing: -0.05em;
      }
      .stat-label {
        font-size: 0.74rem;
        color: var(--fg-subtle);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
      }

      .chips {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin: 0.9rem 0 1.5rem;
      }
      .chip {
        padding: 0.48rem 0.9rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04);
        color: var(--fg-muted);
        font-size: 0.82rem;
        cursor: pointer;
        transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease, color 0.16s ease;
        user-select: none;
      }
      .chip:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.06);
        transform: translateY(-1px);
      }
      .chip.active {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.22);
        color: var(--fg);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 0.95rem;
      }
      .card {
        --card-accent: var(--accent);
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 0.95rem;
        background: rgba(255,255,255,0.02);
        box-shadow: var(--shadow-card);
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
        position: relative;
        overflow: hidden;
        min-height: 248px;
        height: 100%;
      }
      .card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 1px;
        background: linear-gradient(90deg, var(--card-accent), transparent 70%);
        opacity: 0.5;
      }
      .card:hover {
        transform: translateY(-2px);
        border-color: rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.03);
        box-shadow: 0 22px 48px rgba(0, 0, 0, 0.3);
      }
      .card:active { transform: translateY(-1px); }
      .card-top {
        display: flex;
        align-items: center;
        gap: 0.65rem;
      }
      .card .icon {
        display: inline-grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: color-mix(in oklch, var(--card-accent) 12%, transparent);
        border: 1px solid color-mix(in oklch, var(--card-accent) 20%, transparent);
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1;
        color: var(--card-accent);
      }
      .card h3 {
        color: var(--fg);
        font-size: 1.02rem;
        line-height: 1.25;
      }
      .card p {
        color: var(--fg-muted);
        font-size: 0.92rem;
        margin: 0;
        line-height: 1.56;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-body { display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
      .card-footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-top: auto;
      }
      .card-arrow {
        color: var(--fg-subtle);
        font-size: 1rem;
        transition: transform 0.18s ease, color 0.18s ease;
      }
      .card:hover .card-arrow {
        color: var(--fg);
        transform: translateX(2px);
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.38rem;
        min-width: 0;
        max-height: 2.4rem;
        overflow: hidden;
      }
      .tag {
        font-size: 0.7rem;
        padding: 0.3rem 0.65rem;
        border-radius: 8px;
        background: var(--chip-bg);
        color: var(--chip-fg);
        font-weight: 600;
      }
      .tag-extra {
        background: rgba(255,255,255,0.05);
        color: var(--fg);
        border: 1px solid rgba(255,255,255,0.08);
      }
      .tag-more {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.06);
        color: var(--fg-subtle);
      }
      .kind {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.78rem;
        letter-spacing: 0;
        text-transform: none;
        padding: 0;
        font-weight: 600;
        border: 0;
        color: var(--fg-muted);
      }
      .kind-skill { color: var(--kind-skill); }
      .kind-server { color: var(--kind-server); }
      .kind-agent { color: var(--kind-agent); }
      .kind-collection { color: var(--kind-collection); }
      .kind-doc { color: var(--kind-doc); }
      .kind-hook { color: var(--kind-hook); }
      .kind-command { color: var(--kind-command); }
      .kind-tool { color: var(--kind-tool); }

      pre, code {
        font-family: "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
        font-size: 0.85rem;
      }
      pre {
        background: var(--code-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.2rem;
        overflow-x: auto;
        line-height: 1.6;
      }
      code { background: var(--code-bg); padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
      pre code { background: transparent; padding: 0; font-size: inherit; }

      .install {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.85rem;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
        font-size: 0.86rem;
        color: var(--fg);
      }
      .install .install-label {
        margin-bottom: 0;
      }
      .install .install-copy {
        min-width: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .install .cmd {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
        color: var(--fg);
        font-size: 0.92rem;
      }
      .install button.copy {
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        color: var(--fg);
        padding: 0.55rem 0.75rem;
        border-radius: 999px;
        cursor: pointer;
        font-size: 0.78rem;
        font-family: inherit;
        font-weight: 700;
        transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
      }
      .install button.copy:hover {
        transform: translateY(-1px);
        color: var(--fg);
        border-color: rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.07);
      }
      .install button.copy.copied { color: oklch(92% 0.003 265); border-color: rgba(255,255,255,0.18); }

      .markdown h1, .markdown h2, .markdown h3 { margin-top: 2rem; }
      .markdown h1:first-child { margin-top: 0; }
      .markdown p { color: var(--fg); }
      .markdown ul, .markdown ol { color: var(--fg); padding-left: 1.5rem; }
      .markdown li { margin: 0.25rem 0; }
      .markdown blockquote {
        border-left: 3px solid rgba(255,255,255,0.16);
        margin: 1rem 0;
        padding: 0.4rem 0 0.4rem 1rem;
        color: var(--fg-muted);
      }
      .markdown table {
        border-collapse: collapse;
        margin: 1rem 0;
      }
      .markdown th, .markdown td {
        border: 1px solid var(--border);
        padding: 0.4rem 0.75rem;
      }
      .markdown th { background: var(--bg-elev); text-align: left; font-weight: 600; }

      /* ===== Entry detail pages ===== */
      .entry-nav { margin-bottom: 1.25rem; }
      .entry-back {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.52rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        color: var(--fg-muted);
        font-size: 0.84rem;
        font-weight: 500;
        transition: color 0.16s ease, border-color 0.16s ease, background 0.16s ease;
      }
      .entry-back:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.04);
      }
      .entry-header {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        background:
          radial-gradient(ellipse at 0% 100%, color-mix(in oklch, var(--entry-accent) 8%, transparent), transparent 55%),
          rgba(255,255,255,0.02);
        padding: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }
      .entry-header::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 1px;
        background: linear-gradient(90deg, var(--entry-accent), transparent 55%);
        opacity: 0.3;
      }
      .entry-header-top {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }
      .entry-icon {
        display: inline-grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: color-mix(in oklch, var(--entry-accent) 10%, transparent);
        border: 1px solid color-mix(in oklch, var(--entry-accent) 18%, transparent);
        font-size: 1.2rem;
        color: var(--entry-accent);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1;
      }
      .entry-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 1.05;
        letter-spacing: -0.04em;
        margin: 0;
        color: var(--fg);
      }
      .entry-desc {
        color: var(--fg-muted);
        font-size: 1.02rem;
        line-height: 1.65;
        max-width: 68ch;
        margin: 0;
      }
      .entry-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .entry-source {
        color: var(--fg-subtle);
        font-size: 0.82rem;
        margin-top: 2rem;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
      }

      .empty {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--fg-subtle);
      }

      footer.site {
        border-top: 1px solid var(--border);
        padding: 1.75rem 1.25rem;
        color: var(--fg-subtle);
        font-size: 0.82rem;
        text-align: center;
      }
      footer.site a { color: var(--fg-muted); }

      .lead-muted { color: var(--fg-muted); max-width: 76ch; }
      .mt-4 { margin-top: 2rem; }

      @media (max-width: 900px) {
        .hero-grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        .header-inner { padding: 0.7rem 0.9rem; gap: 0.65rem; }
        .brand span.name { display: none; }
        main { padding: 1rem 0.9rem 3rem; }
        nav.primary { gap: 0.2rem; }
        nav.primary a { padding: 0.45rem 0.65rem; }
        .hero { padding-top: 0.35rem; }
        .hero-grid { padding: 1rem; }
        .section-top { flex-direction: column; align-items: flex-start; }
        .stats { grid-template-columns: 1fr 1fr; }
        .install { flex-direction: column; align-items: stretch; }
        .install button.copy { width: 100%; justify-content: center; }
        .grid { grid-template-columns: 1fr; }
      }

      /* ===== Motion ===== */
      @keyframes fsu {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fi {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .hero-kicker { animation: fsu 0.55s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero h1 { animation: fsu 0.65s 0.07s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero p.lede { animation: fsu 0.6s 0.16s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-cta { animation: fsu 0.55s 0.24s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-note { animation: fsu 0.5s 0.32s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-aside { animation: fi 0.72s 0.12s cubic-bezier(0.16, 1, 0.3, 1) both; }
      /* Card icon micro-interaction on card hover */
      .card .icon { transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1), background 0.18s ease, border-color 0.18s ease, color 0.18s ease; }
      .card:hover .icon { transform: scale(1.1) rotate(2deg); }
      /* Scroll reveal states — set via JS, so no initial FOUC */
      .sr {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.52s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.52s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .sr.in { opacity: 1; transform: none; }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t("a11y.skipToContent", locale)}</a>
    <header class="site" role="banner">
      <div class="header-inner">
        <a class="brand" href={localeBase} aria-label={t("nav.brand", locale)}>
          <img class="brand-mark" src={`${base}favicon.svg`} alt="" aria-hidden="true" width="30" height="30" />
          <span class="name">{t("nav.brand", locale)}</span>
        </a>
        <nav class="primary" aria-label={t("a11y.primaryNav", locale)}>
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                item.key === "nav.collections" ? "collections" : undefined,
                isActive(item.href) ? "is-active" : undefined,
              ]}
            >
              {t(item.key, locale)}
            </a>
          ))}
          <a class="github" href="https://github.com/LucasSantana-Dev/forgekit" rel="noopener" aria-label={t("nav.github", locale)}>
            {t("nav.github", locale)} <span aria-hidden="true">↗</span>
          </a>
          <LanguageSwitcher locale={locale} />
        </nav>
      </div>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site" role="contentinfo">
      <a href="https://github.com/LucasSantana-Dev/forgekit" rel="noopener">{t("footer.source", locale)}</a>
      · {t("footer.license", locale)}
      · {t("footer.builtWith", locale)} <a href="https://astro.build" rel="noopener">Astro</a>,
      {t("footer.runsOn", locale)} <a href="https://workers.cloudflare.com" rel="noopener">Cloudflare Workers</a>
    </footer>

    <script is:inline>
      // Copy-to-clipboard for .install buttons
      document.addEventListener("click", (e) => {
        const btn = (e.target instanceof Element ? e.target.closest("button.copy") : null);
        if (!btn) return;
        const text = btn.dataset.copy || btn.previousElementSibling?.textContent || "";
        navigator.clipboard.writeText(text.trim()).then(() => {
          const original = btn.textContent;
          btn.textContent = "✓ copied";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove("copied");
          }, 1500);
        });
      });
    </script>
    <script is:inline>
      // Scroll reveal with per-grid card stagger
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (!window.IntersectionObserver) return;
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.06, rootMargin: "0px 0px -28px 0px" });

        requestAnimationFrame(function () {
          var vh = window.innerHeight;
          document.querySelectorAll(".card, .section-top, .workflow-card").forEach(function (el) {
            var top = el.getBoundingClientRect().top;
            if (top > vh * 0.88) {
              el.classList.add("sr");
              obs.observe(el);
            }
          });
          // Stagger cards per grid section
          document.querySelectorAll(".grid").forEach(function (grid) {
            grid.querySelectorAll(".card.sr").forEach(function (card, i) {
              card.style.transitionDelay = Math.min(i * 42, 180) + "ms";
            });
          });
        });
      })();
    </script>
  </body>
</html>
