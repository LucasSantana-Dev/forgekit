---
import type { Locale } from "../lib/i18n";
import { resolveLocale, t } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  noindex?: boolean;
  /**
   * Extra keyword-rich phrase appended to the page title to land it inside the
   * 30-60 char SEO range without bloating the visible site banner. Use 4-30
   * chars; we'll trim if the resulting `<title>` would exceed 65.
   */
  titleSuffix?: string;
}
const {
  title,
  description = "Curated catalog of skills, agents, MCP servers, hooks, commands, and tools for Claude Code, Codex, Gemini, and local LLMs.",
  locale = resolveLocale(Astro.url.pathname),
  ogImage,
  noindex = false,
  titleSuffix,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString().replace(/\/$/, "") ?? "";
const localeBase = base;
const htmlLang = "en";
const ogLocale = "en_US";

const pathname = Astro.url.pathname;
const canonicalPath = pathname.endsWith("/") || pathname.includes(".") ? pathname : `${pathname}/`;
const canonicalUrl = `${site}${canonicalPath}`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${site}${ogImage.startsWith("/") ? ogImage : `/${ogImage}`}`)
  : `${site}/og-image.svg`;

// Land the page title inside the 30-60 char SEO sweet spot. The bare
// `Title · Forge Kit` is too short on most pages (often <30 chars), so we
// append a `titleSuffix` provided by the page (or fall back to a generic suffix
// derived from the path). Truncate if the combined string exceeds 65 chars.
const baseTitle = `${title} · Forge Kit`;
const fallbackSuffix =
  pathname === "/" || pathname === ""
    ? "AI-assisted dev catalog"
    : pathname.startsWith("/skills") ? "Claude Code skills catalog"
    : pathname.startsWith("/agents") ? "Claude Code sub-agents"
    : pathname.startsWith("/servers") ? "Servers for AI agents"
    : pathname.startsWith("/hooks") ? "Claude Code hooks"
    : pathname.startsWith("/commands") ? "Claude Code slash commands"
    : pathname.startsWith("/tools") ? "developer CLIs and scripts"
    : pathname.startsWith("/collections") ? "curated forgekit bundles"
    : pathname.startsWith("/docs") ? "AI-dev reference docs"
    : pathname.startsWith("/tutorials") ? "step-by-step guides"
    : pathname.startsWith("/providers") ? "Claude, Codex, Gemini, Cursor"
    : pathname.startsWith("/search") ? "search the catalog"
    : null;
const effectiveSuffix = titleSuffix ?? fallbackSuffix;
// Land combined title in the SEO 30-60 char sweet spot. We bias toward the
// suffix being included whenever the bare title is short, then hard-cap at 60.
let fullTitle = effectiveSuffix && baseTitle.length < 45
  ? `${baseTitle} — ${effectiveSuffix}`
  : baseTitle;
if (fullTitle.length > 60) fullTitle = `${fullTitle.slice(0, 57).trimEnd()}…`;

// Land meta description in the SEO sweet spot (120-155 chars). Pad short
// descriptions with a path-derived suffix; trim long ones at a word boundary.
const padSuffix =
  pathname.startsWith("/skills/") ? " — installable Claude Code skill from the Forge Kit catalog of AI-assisted dev tooling."
  : pathname.startsWith("/agents/") ? " — Claude Code sub-agent from the Forge Kit catalog of AI-assisted dev tooling."
  : pathname.startsWith("/servers/") ? " — Model Context Protocol server from the Forge Kit catalog for Claude, Codex, and Gemini."
  : pathname.startsWith("/hooks/") ? " — Claude Code hook from the Forge Kit catalog of AI-assisted dev tooling."
  : pathname.startsWith("/commands/") ? " — Claude Code slash command from the Forge Kit catalog of AI-assisted dev tooling."
  : pathname.startsWith("/tools/") ? " — standalone CLI from the Forge Kit catalog of AI-assisted dev tooling."
  : pathname.startsWith("/collections/") ? " — curated forgekit bundle of skills, agents, hooks, and MCP servers."
  : pathname.startsWith("/docs/") ? " — Forge Kit reference doc on AI-assisted development workflows and architecture."
  : pathname.startsWith("/tutorials/") ? " — step-by-step Forge Kit tutorial for installing and configuring catalog entries."
  : pathname.startsWith("/providers/") ? " — Forge Kit catalog grouped by AI provider for Claude, Codex, Gemini, and Cursor."
  : "";
// Optional second-tier filler appended only when the first padSuffix still
// leaves the description under the 120-char SEO floor.
const padFiller = " Install with one command: `npx forge-kit install <slug>`.";
let metaDescription = description;
if (metaDescription.length < 120 && padSuffix) {
  metaDescription = `${metaDescription.replace(/\s+$/, "").replace(/\.$/, "")}${padSuffix}`;
}
if (metaDescription.length < 120 && padSuffix) {
  metaDescription = `${metaDescription.replace(/\s+$/, "").replace(/\.$/, "")}${padFiller}`;
}
if (metaDescription.length > 155) {
  const cut = metaDescription.slice(0, 152);
  // Prefer a word boundary, but only if it leaves us within the 120-155 SEO
  // sweet spot. Otherwise hard-cut at 152 to avoid undershooting the floor.
  const lastSpace = cut.lastIndexOf(" ");
  const wordCut = lastSpace > 0 ? cut.slice(0, lastSpace) : cut;
  metaDescription = `${(wordCut.length >= 120 ? wordCut : cut).trimEnd()}…`;
}

const currentPath = pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: `${localeBase}skills/`, key: "nav.skills" },
  { href: `${localeBase}agents/`, key: "nav.agents" },
  { href: `${localeBase}servers/`, key: "nav.servers" },
  { href: `${localeBase}tools/`, key: "nav.tools" },
  { href: `${localeBase}hooks/`, key: "nav.hooks" },
  { href: `${localeBase}collections/`, key: "nav.collections" },
  { href: `${localeBase}commands/`, key: "nav.commands" },
  { href: `${localeBase}providers/`, key: "nav.providers" },
  { href: `${localeBase}docs/`, key: "nav.docs" },
  { href: `${localeBase}tutorials/`, key: "nav.tutorials" },
];
const isActive = (href: string) => {
  const trimmed = href.replace(/\/$/, "") || "/";
  return currentPath === trimmed || currentPath.startsWith(`${trimmed}/`);
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Forge Kit",
  alternateName: "forge-kit",
  description: metaDescription,
  url: site || canonicalUrl,
  inLanguage: htmlLang,
  publisher: {
    "@type": "Person",
    name: "Lucas Santana",
    url: "https://github.com/LucasSantana-Dev",
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${site}${localeBase}search/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#050505" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="Forge Kit" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />

    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style is:global>
      :root {
        --bg: oklch(7% 0.004 265);
        --bg-elev: oklch(11% 0.004 265);
        --bg-panel: oklch(15% 0.005 265);
        --bg-hover: oklch(18% 0.005 265);
        --fg: oklch(97% 0.003 265);
        --fg-muted: oklch(86% 0.007 265);
        --fg-subtle: oklch(72% 0.006 265);
        --border: oklch(100% 0 0 / 0.22);
        --border-strong: oklch(100% 0 0 / 0.34);
        --accent: oklch(87% 0.005 265);
        --accent-hot: oklch(99% 0.002 265);
        --accent-soft: oklch(100% 0 0 / 0.08);
        --code-bg: oklch(100% 0 0 / 0.08);
        --chip-bg: oklch(100% 0 0 / 0.10);
        --chip-fg: oklch(91% 0.006 75);

        --kind-skill:      oklch(75% 0.08 75);
        --kind-agent:      oklch(72% 0.10 275);
        --kind-server:     oklch(73% 0.09 185);
        --kind-collection: oklch(71% 0.10 15);
        --kind-doc:        oklch(70% 0.09 235);
        --kind-hook:       oklch(73% 0.11 45);
        --kind-command:    oklch(85% 0.015 85);
        --kind-tool:       oklch(72% 0.09 145);

        --radius: 14px;
        --radius-sm: 10px;
        --radius-lg: 22px;
        --shadow-card: 0 18px 38px rgba(0, 0, 0, 0.28);

        font-family: "Geist", "Inter", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-feature-settings: "cv11", "ss01", "ss03";
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }

      :focus-visible {
        outline: 2px solid var(--accent-hot);
        outline-offset: 3px;
        border-radius: 6px;
      }

      .skip-link {
        position: absolute;
        top: 0;
        left: 0;
        padding: 0.65rem 1rem;
        background: var(--fg);
        color: #050505;
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 0 0 8px 0;
        transform: translateY(-110%);
        transition: transform 0.18s ease;
        z-index: 100;
      }
      .skip-link:focus-visible {
        transform: translateY(0);
        color: #050505;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(ellipse at -10% 110%, oklch(75% 0.08 75 / 0.09), transparent 50%),
          radial-gradient(circle at top, rgba(255, 255, 255, 0.05), transparent 26%),
          radial-gradient(circle at 85% 0%, rgba(255, 255, 255, 0.03), transparent 18%),
          linear-gradient(180deg, oklch(5% 0.004 265) 0%, oklch(7% 0.004 265) 100%);
        color: var(--fg);
        line-height: 1.6;
        font-size: 15px;
        -webkit-font-smoothing: antialiased;
        position: relative;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(rgba(255,255,255,0.015), rgba(255,255,255,0.015)),
          radial-gradient(circle at 50% 0%, rgba(255,255,255,0.035), transparent 28%);
        opacity: 0.4;
      }
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0.032;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { color: var(--accent-hot); }

      header.site {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(5, 5, 5, 0.84);
        backdrop-filter: blur(18px) saturate(120%);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.16);
      }
      .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        color: var(--fg);
        font-weight: 650;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .brand:hover { color: var(--fg); }
      .brand-mark {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        display: block;
        object-fit: contain;
        padding: 5px;
      }
      nav.primary {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        margin-left: auto;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      nav.primary a {
        color: var(--fg-muted);
        padding: 0.42rem 0.72rem;
        border-radius: 10px;
        font-size: 0.88rem;
        border: 1px solid transparent;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease, transform 0.16s ease;
      }
      nav.primary a:hover {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--border);
        transform: translateY(-1px);
      }
      nav.primary a.github {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.45rem 0.65rem;
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.08);
      }
      nav.primary a.github svg {
        display: block;
        flex-shrink: 0;
      }
      nav.primary a[aria-current="page"],
      nav.primary a.is-active {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.18);
      }

      main:focus-visible {
        outline: none;
      }

      .workflow-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
        gap: 1rem;
      }
      .workflow-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.25rem;
      }
      .workflow-card-header h3 {
        margin: 0 0 0.4rem;
        font-size: 1.05rem;
        line-height: 1.25;
      }
      .workflow-card-header p {
        margin: 0;
        font-size: 0.92rem;
        line-height: 1.55;
        max-width: 52ch;
      }
      .workflow-card-footer {
        margin-top: auto;
        align-self: flex-start;
        font-size: 0.85rem;
      }
      @media (max-width: 720px) {
        .workflow-grid {
          grid-template-columns: 1fr;
        }
      }

      main {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2.5rem 2rem 6rem;
      }
      h1, h2, h3, h4 { color: var(--fg); letter-spacing: -0.04em; }
      h1 {
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        line-height: 1.05;
        margin: 0;
        font-weight: 720;
      }
      h2 {
        font-size: clamp(1.3rem, 2.2vw, 1.65rem);
        margin: 0;
        font-weight: 720;
      }
      h3 { font-size: 1.04rem; margin: 0; font-weight: 650; }
      p { color: var(--fg-muted); margin: 0.5rem 0; }

      .hero {
        padding: 2.5rem 0 4rem;
        margin-bottom: 3rem;
        position: relative;
      }
      .hero::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, oklch(75% 0.08 75 / 0.45) 0%, oklch(75% 0.08 75 / 0.12) 50%, transparent 100%);
      }
      .hero-shell {
        position: relative;
        overflow: visible;
        border: none;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
      }
      .hero-shell::before {
        content: "";
        position: absolute;
        top: -40%;
        left: 60%;
        width: 55%;
        height: 130%;
        background: radial-gradient(ellipse at center, oklch(75% 0.08 75 / 0.07), transparent 65%);
        pointer-events: none;
        z-index: 0;
      }
      .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: clamp(2rem, 4vw, 3rem);
        padding: 0;
        align-items: stretch;
      }
      .hero-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.4rem;
        min-width: 0;
      }
      .hero-kicker {
        display: inline-flex;
        align-self: flex-start;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.7rem;
        border-radius: 999px;
        border: 1px solid oklch(75% 0.08 75 / 0.28);
        background: oklch(75% 0.08 75 / 0.07);
        color: var(--kind-skill);
        font-size: 0.74rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .hero h1 {
        font-size: clamp(2.9rem, 6vw, 5.4rem);
        line-height: 0.92;
        color: var(--fg);
        max-width: 11ch;
      }
      .hero p.lede {
        max-width: 72ch;
        font-size: 1.08rem;
        line-height: 1.7;
        color: var(--fg-muted);
      }
      .hero-cta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.72rem 1.05rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255, 255, 255, 0.03);
        color: var(--fg);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
      }
      .btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255,255,255,0.16);
        color: var(--fg);
      }
      .btn:active { transform: translateY(0); }
      .btn-primary {
        background: oklch(75% 0.08 75);
        border-color: oklch(78% 0.09 75);
        color: oklch(12% 0.003 265);
        box-shadow: 0 8px 28px oklch(75% 0.08 75 / 0.35);
      }
      .btn-primary:hover { color: oklch(12% 0.003 265); background: oklch(78% 0.085 75); box-shadow: 0 10px 32px oklch(75% 0.08 75 / 0.45); }
      .hero-note {
        font-size: 0.82rem;
        letter-spacing: 0.01em;
        color: var(--fg-subtle);
      }

      .hero-aside {
        display: grid;
        gap: 0.9rem;
        align-content: stretch;
      }

      .hero-surface {
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 18px;
        background: rgba(255,255,255,0.04);
        padding: 1.25rem;
      }
      .hero-surface-title,
      .search-panel .search-label,
      .install-label {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-bottom: 0.8rem;
        color: var(--fg-subtle);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .hero-surface-title::before,
      .search-panel .search-label::before,
      .install-label::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--kind-skill);
        box-shadow: 0 0 0 4px oklch(75% 0.08 75 / 0.14);
      }
      .hero-install {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        padding: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
      }
      .hero-install .hero-surface-title {
        margin-bottom: 0;
      }
      .hero-install p {
        color: var(--fg-muted);
        font-size: 0.92rem;
        margin: 0;
      }
      .hero-install .install {
        border-color: oklch(75% 0.08 75 / 0.38);
        background: oklch(75% 0.08 75 / 0.10);
        box-shadow: inset 0 1px 0 oklch(75% 0.08 75 / 0.12);
        transition: box-shadow 0.18s ease, border-color 0.18s ease;
      }
      .hero-install .install:hover {
        border-color: oklch(75% 0.08 75 / 0.55);
        box-shadow: inset 0 1px 0 oklch(75% 0.08 75 / 0.18), 0 8px 24px oklch(75% 0.08 75 / 0.18);
      }
      .kind-legend {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.5rem;
      }
      .kind-legend-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.8rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.02);
        color: var(--fg-muted);
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
        text-decoration: none;
      }
      .kind-legend-item:hover {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.12);
        color: var(--fg);
      }
      .kind-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: var(--dot-color, var(--fg-subtle));
      }
      .kind-legend-count {
        margin-left: auto;
        font-size: 0.75rem;
        color: var(--fg-subtle);
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .section-top {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        margin: 4.5rem 0 2rem;
      }
      .section-top h2 + p { max-width: 65ch; }

      .section-collections-header {
        margin-bottom: 1.2rem;
      }
      .section-title {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-bottom: 0.65rem;
        color: var(--fg-subtle);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .section-title::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--kind-collection);
        box-shadow: 0 0 0 4px oklch(71% 0.10 15 / 0.14);
      }
      .section-lede {
        max-width: 65ch;
        color: var(--fg-muted);
        margin: 0 0 0.8rem;
      }

      .section-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.58rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: var(--fg);
        font-size: 0.88rem;
        font-weight: 600;
        white-space: nowrap;
      }
      .section-link:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.16);
        background: rgba(255,255,255,0.06);
      }

      .search-panel {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        background: rgba(255,255,255,0.02);
        padding: 1rem;
        box-shadow: var(--shadow-card);
        margin: 0 0 1.25rem;
      }
      .search-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .search-wrap {
        margin: 0;
        position: relative;
        flex: 1;
      }
      .view-toggle {
        display: flex;
        align-items: center;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
        flex-shrink: 0;
      }
      .view-btn {
        display: inline-grid;
        place-items: center;
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--fg-subtle);
        transition: background 0.14s ease, color 0.14s ease;
      }
      .view-btn + .view-btn {
        border-left: 1px solid rgba(255,255,255,0.1);
      }
      .view-btn:hover { background: rgba(255,255,255,0.06); color: var(--fg); }
      .view-btn.active {
        background: rgba(255,255,255,0.1);
        color: var(--fg);
      }
      .search-wrap input {
        width: 100%;
        padding: 0.95rem 1rem 0.95rem 2.75rem;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        color: var(--fg);
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
      }
      .search-wrap input:focus {
        outline: none;
        border-color: rgba(255,255,255,0.22);
        box-shadow: 0 0 0 4px rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.04);
      }
      .search-wrap .search-icon {
        position: absolute;
        left: 0.95rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg-subtle);
        pointer-events: none;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 0.85rem;
        margin: 2rem 0 3rem;
      }
      .stat {
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
        padding: 0.95rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .stat-value {
        font-size: 1.75rem;
        font-weight: 760;
        color: var(--fg);
        letter-spacing: -0.05em;
      }
      .stat-label {
        font-size: 0.74rem;
        color: var(--fg-subtle);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
      }

      .chips {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin: 0.9rem 0 1.5rem;
      }
      .chip {
        padding: 0.48rem 0.9rem;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        color: var(--fg-muted);
        font-size: 0.82rem;
        cursor: pointer;
        transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease, color 0.16s ease;
        user-select: none;
      }
      .chip:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.22);
        background: rgba(255,255,255,0.1);
        transform: translateY(-1px);
      }
      .chip.active {
        background: rgba(255,255,255,0.12);
        border-color: rgba(255,255,255,0.22);
        color: var(--fg);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1.5rem;
      }
      .grid.list-view {
        grid-template-columns: 1fr;
        grid-auto-rows: auto;
        gap: 0.4rem;
      }
      .grid.list-view .card {
        flex-direction: row;
        align-items: center;
        height: auto;
        padding: 0.65rem 1rem;
        gap: 1rem;
        border-radius: 10px;
      }
      .grid.list-view .card:hover {
        transform: none;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
      }
      .grid.list-view .card-head {
        flex-shrink: 0;
        width: 200px;
        min-width: 0;
      }
      .grid.list-view .card-id {
        font-size: 0.78rem;
        color: var(--card-accent);
        opacity: 0.85;
      }
      .grid.list-view .card-body {
        flex: 1;
        flex-direction: row;
        align-items: center;
        gap: 1rem;
        min-width: 0;
      }
      .grid.list-view .card h3 {
        flex-shrink: 0;
        width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.92rem;
        font-weight: 600;
      }
      .grid.list-view .card p {
        flex: 1;
        -webkit-line-clamp: 1;
        min-width: 0;
        font-size: 0.85rem;
        margin: 0;
      }
      .grid.list-view .card-footer {
        flex-shrink: 0;
        margin: 0;
        gap: 0.6rem;
      }
      .grid.list-view .tags {
        max-width: 260px;
        flex-wrap: nowrap;
        overflow: hidden;
      }
      .grid.list-view .card-arrow {
        opacity: 0.5;
      }
      @media (max-width: 900px) {
        .grid.list-view .card-head { width: 150px; }
        .grid.list-view .card h3 { width: 160px; }
        .grid.list-view .tags { display: none; }
      }
      @media (max-width: 640px) {
        .grid.list-view .card { flex-wrap: wrap; gap: 0.4rem 0.8rem; }
        .grid.list-view .card-head { width: auto; }
        .grid.list-view .card-body { flex-basis: 100%; flex-direction: column; align-items: flex-start; gap: 0.15rem; }
        .grid.list-view .card h3 { width: auto; }
      }
      .card {
        --card-accent: var(--accent);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 12px;
        padding: 1.1rem 1.15rem;
        background: rgba(255,255,255,0.025);
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
        position: relative;
        overflow: hidden;
        height: 220px;
        text-decoration: none;
      }
      .grid { grid-auto-rows: 220px; }

      /* Standard screen-reader-only utility for landmark labels and hidden
         headings that satisfy a11y heading-order without polluting the visual
         layout. */
      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Collapsible category sections — markup lives on each listing page,
         these rules turn the header into an interactive toggle and hide the
         grid + content when collapsed. */
      .category-header-toggle {
        cursor: pointer;
        user-select: none;
        position: relative;
        align-items: center !important;
        padding-right: 0.4rem;
        border-radius: 6px;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .category-header-toggle:hover {
        background: rgba(255, 255, 255, 0.03);
      }
      .category-header-toggle:hover .category-title {
        color: var(--fg);
      }
      .category-header-toggle:focus-visible {
        outline: 2px solid var(--accent-hot);
        outline-offset: 3px;
      }
      .category-chevron {
        margin-left: auto;
        color: var(--fg-subtle);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        transition: transform 0.2s ease, color 0.18s ease, background 0.15s ease;
      }
      .category-header-toggle:hover .category-chevron {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.06);
      }
      .entry-category.collapsed .category-chevron {
        transform: rotate(-90deg);
      }
      .entry-category.collapsed .grid,
      .entry-category.collapsed > *:not(.category-header) {
        display: none !important;
      }
      .entry-category.collapsed .category-header {
        margin-bottom: 0;
        padding-bottom: 0.4rem;
        border-bottom-style: dashed;
        opacity: 0.9;
      }

      .card:hover {
        transform: translateY(-2px);
        border-color: color-mix(in oklch, var(--card-accent) 35%, rgba(255,255,255,0.15));
        background: rgba(255,255,255,0.04);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28),
                    inset 0 0 0 1px color-mix(in oklch, var(--card-accent) 8%, transparent);
      }
      .card:active { transform: translateY(-1px); }

      .card-head {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }
      .card-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--card-accent);
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--card-accent) 18%, transparent);
        flex-shrink: 0;
      }
      .card-id {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--fg-subtle);
        letter-spacing: 0.01em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
      }
      .card:hover .card-id {
        color: var(--fg-muted);
      }

      .card h3 {
        color: var(--fg);
        font-size: 1.02rem;
        line-height: 1.3;
        font-weight: 600;
        margin: 0;
      }
      .card p {
        color: var(--fg-muted);
        font-size: 0.9rem;
        margin: 0;
        line-height: 1.55;
        max-width: 68ch;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-body { display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
      .card-footer {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-top: auto;
      }
      .card-arrow {
        color: var(--fg-subtle);
        font-size: 0.95rem;
        opacity: 0;
        transition: transform 0.18s ease, color 0.18s ease, opacity 0.18s ease;
        flex-shrink: 0;
      }
      .card:hover .card-arrow {
        color: var(--card-accent);
        transform: translate(2px, -2px);
        opacity: 1;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        min-width: 0;
        max-height: 1.65rem;
        overflow: hidden;
        align-items: center;
      }
      .tag {
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
        font-size: 0.74rem;
        padding: 0;
        background: transparent;
        color: var(--fg-subtle);
        font-weight: 500;
        letter-spacing: 0.01em;
        transition: color 0.15s ease;
      }
      .card:hover .tag { color: var(--fg-muted); }
      .tag-extra {
        font-family: inherit;
        font-size: 0.7rem;
        padding: 0.18rem 0.5rem;
        border-radius: 6px;
        background: color-mix(in oklch, var(--card-accent) 12%, transparent);
        color: var(--card-accent);
        border: 1px solid color-mix(in oklch, var(--card-accent) 22%, transparent);
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: lowercase;
      }
      .tag-more {
        font-family: inherit;
        color: var(--fg-subtle);
        font-size: 0.72rem;
      }
      .kind {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        letter-spacing: 0;
        text-transform: none;
        padding: 0.25rem 0.5rem;
        font-weight: 600;
        border: 0;
        color: var(--fg-muted);
      }
      .kind-skill { color: var(--kind-skill); }
      .kind-server { color: var(--kind-server); }
      .kind-agent { color: var(--kind-agent); }
      .kind-collection { color: var(--kind-collection); }
      .kind-doc { color: var(--kind-doc); }
      .kind-hook { color: var(--kind-hook); }
      .kind-command { color: var(--kind-command); }
      .kind-tool { color: var(--kind-tool); }

      pre, code {
        font-family: "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
        font-size: 0.85rem;
      }
      pre {
        background: var(--code-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.2rem;
        overflow-x: auto;
        line-height: 1.6;
      }
      code { background: var(--code-bg); padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
      pre code { background: transparent; padding: 0; font-size: inherit; }

      .install {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.85rem;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.03);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
        font-size: 0.86rem;
        color: var(--fg);
      }
      .install .install-label {
        margin-bottom: 0;
      }
      .install .install-copy {
        min-width: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .install .cmd {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
        color: var(--fg);
        font-size: 0.92rem;
      }
      /* Inside constrained aside column, stack vertically so cmd gets full width */
      .hero-install .install {
        flex-direction: column;
        align-items: stretch;
        gap: 0.65rem;
      }
      .hero-install .install .install-copy {
        width: 100%;
      }
      .hero-install .install button.copy {
        align-self: flex-end;
        width: auto;
      }
      .install button.copy {
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.06);
        color: var(--fg);
        padding: 0.55rem 0.75rem;
        border-radius: 999px;
        cursor: pointer;
        font-size: 0.78rem;
        font-family: inherit;
        font-weight: 700;
        transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
      }
      .install button.copy:hover {
        transform: translateY(-1px);
        color: var(--fg);
        border-color: rgba(255,255,255,0.22);
        background: rgba(255,255,255,0.1);
      }
      .install button.copy.copied { color: oklch(92% 0.003 265); border-color: rgba(255,255,255,0.18); }

      .markdown h1, .markdown h2, .markdown h3 { margin-top: 2rem; }
      .markdown h1:first-child { margin-top: 0; }
      .markdown p { color: var(--fg); max-width: 70ch; }
      .markdown ul, .markdown ol { color: var(--fg); padding-left: 1.5rem; }
      .markdown li { margin: 0.25rem 0; }
      .markdown blockquote {
        border-left: 3px solid rgba(255,255,255,0.16);
        margin: 1rem 0;
        padding: 0.4rem 0 0.4rem 1rem;
        color: var(--fg-muted);
      }
      .markdown table {
        border-collapse: collapse;
        margin: 1rem 0;
      }
      .markdown th, .markdown td {
        border: 1px solid var(--border);
        padding: 0.4rem 0.75rem;
      }
      .markdown th { background: var(--bg-elev); text-align: left; font-weight: 600; }

      /* ===== Entry detail pages ===== */
      .entry-nav { margin-bottom: 1.25rem; }
      .entry-back {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.52rem 0.85rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.02);
        color: var(--fg-muted);
        font-size: 0.84rem;
        font-weight: 500;
        transition: color 0.16s ease, border-color 0.16s ease, background 0.16s ease;
      }
      .entry-back:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.04);
      }
      .entry-header {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        background:
          radial-gradient(ellipse at 0% 100%, color-mix(in oklch, var(--entry-accent) 8%, transparent), transparent 55%),
          rgba(255,255,255,0.02);
        padding: 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }

      .entry-header-top {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }
      .entry-icon {
        display: inline-grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: color-mix(in oklch, var(--entry-accent) 10%, transparent);
        border: 1px solid color-mix(in oklch, var(--entry-accent) 18%, transparent);
        font-size: 1.2rem;
        color: var(--entry-accent);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1;
      }
      .entry-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 1.05;
        letter-spacing: -0.04em;
        margin: 0;
        color: var(--fg);
      }
      .entry-desc {
        color: var(--fg-muted);
        font-size: 1.02rem;
        line-height: 1.65;
        max-width: 68ch;
        margin: 0;
      }
      .entry-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .entry-source {
        color: var(--fg-subtle);
        font-size: 0.82rem;
        margin-top: 2rem;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
      }

      .empty {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--fg-subtle);
      }

      .empty-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        padding: 5rem 1rem;
        color: var(--fg-subtle);
        text-align: center;
      }
      .empty-page svg {
        opacity: 0.35;
        margin-bottom: 0.5rem;
      }
      .empty-page .empty-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--fg-muted);
        margin: 0;
      }
      .empty-page .empty-sub {
        font-size: 0.9rem;
        color: var(--fg-subtle);
        margin: 0;
        max-width: 36ch;
      }
      .empty-page .empty-cta {
        margin-top: 0.5rem;
        font-size: 0.83rem;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.3rem 0.7rem;
        color: var(--accent);
      }

      footer.site {
        border-top: 1px solid var(--border);
        padding: 1.75rem 1.25rem;
        color: var(--fg-subtle);
        font-size: 0.82rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        align-items: center;
      }
      footer.site a { color: var(--fg-muted); }
      footer.site .footer-credits { color: var(--fg-muted); font-size: 0.875rem; }
      footer.site .footer-credits a { color: var(--fg); }

      .lead-muted { color: var(--fg-muted); max-width: 96ch; }
      .mt-4 { margin-top: 2rem; }

      @media (max-width: 900px) {
        .hero-grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        .header-inner { padding: 0.7rem 0.9rem; gap: 0.65rem; }
        .brand span.name { display: none; }
        main { padding: 1rem 0.9rem 3rem; }
        nav.primary { gap: 0.2rem; }
        nav.primary a { padding: 0.45rem 0.65rem; }
        .hero { padding-top: 0.35rem; }
        .hero-grid { padding: 1rem; }
        .section-top { flex-direction: column; align-items: flex-start; }
        .stats { grid-template-columns: 1fr 1fr; }
        .install { flex-direction: column; align-items: stretch; }
        .install button.copy { width: 100%; justify-content: center; }
        .grid { grid-template-columns: 1fr; }
      }

      /* ===== Motion ===== */
      @keyframes fsu {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fi {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .hero-kicker { animation: fsu 0.55s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero h1 { animation: fsu 0.65s 0.07s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero p.lede { animation: fsu 0.6s 0.16s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-cta { animation: fsu 0.55s 0.24s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-note { animation: fsu 0.5s 0.32s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .hero-aside { animation: fi 0.72s 0.12s cubic-bezier(0.16, 1, 0.3, 1) both; }
      /* Card icon micro-interaction on card hover */
      .card .icon { transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1), background 0.18s ease, border-color 0.18s ease, color 0.18s ease; }
      .card:hover .icon { transform: scale(1.1) rotate(2deg); }
      /* Scroll reveal states — set via JS, so no initial FOUC */
      .sr {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.52s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.52s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .sr.in { opacity: 1; transform: none; }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t("a11y.skipToContent", locale)}</a>
    <header class="site" role="banner">
      <div class="header-inner">
        <a class="brand" href={localeBase} aria-label={t("nav.brand", locale)}>
          <img class="brand-mark" src={`${base}favicon.svg`} alt="" aria-hidden="true" width="30" height="30" />
          <span class="name">{t("nav.brand", locale)}</span>
        </a>
        <nav class="primary" aria-label={t("a11y.primaryNav", locale)}>
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                isActive(item.href) ? "is-active" : undefined,
              ]}
            >
              {t(item.key, locale)}
            </a>
          ))}
          <a class="github" href="https://github.com/LucasSantana-Dev/forgekit" rel="noopener" aria-label={t("nav.github", locale)}>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .322.216.694.825.576C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </nav>
      </div>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site" role="contentinfo">
      <div class="footer-credits">Made by <a href="https://github.com/LucasSantana-Dev" rel="noopener">Lucas Santana</a></div>
      <div class="footer-links">
        <a href={`${base}about/`}>About</a>
        · <a href={`${base}contact/`}>Contact</a>
        · <a href={`${base}privacy/`}>Privacy</a>
        · <a href="https://github.com/LucasSantana-Dev/forgekit" rel="noopener">{t("footer.source", locale)}</a>
        · {t("footer.license", locale)}
        · {t("footer.builtWith", locale)} <a href="https://astro.build" rel="noopener">Astro</a>,
        {t("footer.runsOn", locale)} <a href="https://workers.cloudflare.com" rel="noopener">Cloudflare Workers</a>
      </div>
    </footer>

    <script is:inline>
      // Collapsible category sections. Click the header to fold/unfold; state
      // is persisted per-page in localStorage so a refresh keeps your view.
      (function () {
        function init() {
          const sections = document.querySelectorAll("section.entry-category");
          if (sections.length === 0) return;
          const STORAGE_KEY = "fk-collapsed:" + window.location.pathname;
          let collapsed = new Set();
          try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (raw) collapsed = new Set(JSON.parse(raw));
          } catch (e) {}
          const persist = () => {
            try {
              localStorage.setItem(STORAGE_KEY, JSON.stringify([...collapsed]));
            } catch (e) {}
          };

          sections.forEach((section) => {
            const header = section.querySelector(".category-header");
            if (!header || header.dataset.collapseInit === "1") return;
            header.dataset.collapseInit = "1";
            header.setAttribute("role", "button");
            header.setAttribute("tabindex", "0");
            header.classList.add("category-header-toggle");
            if (!header.querySelector(".category-chevron")) {
              const chev = document.createElement("span");
              chev.className = "category-chevron";
              chev.setAttribute("aria-hidden", "true");
              chev.innerHTML =
                '<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4.5 7l4.5 4.5L13.5 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
              header.appendChild(chev);
            }
            const id = section.id || (header.textContent || "").trim();
            if (collapsed.has(id)) section.classList.add("collapsed");
            header.setAttribute("aria-expanded", section.classList.contains("collapsed") ? "false" : "true");

            const toggle = (e) => {
              if (e) e.preventDefault();
              const isCollapsed = section.classList.toggle("collapsed");
              header.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
              if (isCollapsed) collapsed.add(id);
              else collapsed.delete(id);
              persist();
            };
            header.addEventListener("click", toggle);
            header.addEventListener("keydown", (e) => {
              if (e.key === "Enter" || e.key === " ") toggle(e);
            });
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>
    <script is:inline>
      // Scroll-spy: highlight the sidebar link for the section currently in view.
      (function () {
        if (!window.IntersectionObserver) return;
        const sidebar = document.querySelector(".page-sidebar nav");
        if (!sidebar) return;
        const sections = Array.from(document.querySelectorAll("section.entry-category[id]"));
        if (sections.length === 0) return;
        const linkFor = (id) => sidebar.querySelector(`a[href="#${id}"]`);
        const setActive = (id) => {
          sidebar.querySelectorAll("a.sidebar-link").forEach((a) => a.classList.remove("is-active"));
          const link = linkFor(id);
          if (link) link.classList.add("is-active");
        };
        let activeId = sections[0].id;
        setActive(activeId);
        const obs = new IntersectionObserver(
          (entries) => {
            // Pick the entry closest to the top that's currently intersecting.
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible.length > 0) {
              const id = visible[0].target.id;
              if (id !== activeId) {
                activeId = id;
                setActive(id);
              }
            }
          },
          { rootMargin: "-20% 0px -60% 0px", threshold: 0 },
        );
        sections.forEach((s) => obs.observe(s));
      })();
    </script>
    <script is:inline>
      // Copy-to-clipboard for .install buttons
      document.addEventListener("click", (e) => {
        const btn = (e.target instanceof Element ? e.target.closest("button.copy") : null);
        if (!btn) return;
        const text = btn.dataset.copy || btn.previousElementSibling?.textContent || "";
        navigator.clipboard.writeText(text.trim()).then(() => {
          const original = btn.textContent;
          btn.textContent = "✓ copied";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove("copied");
          }, 1500);
        });
      });
    </script>
    <script is:inline>
      // Scroll reveal with per-grid card stagger
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (!window.IntersectionObserver) return;
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.06, rootMargin: "0px 0px -28px 0px" });

        requestAnimationFrame(function () {
          var vh = window.innerHeight;
          document.querySelectorAll(".card, .section-top, .workflow-card").forEach(function (el) {
            var top = el.getBoundingClientRect().top;
            if (top > vh * 0.88) {
              el.classList.add("sr");
              obs.observe(el);
            }
          });
          // Stagger cards per grid section
          document.querySelectorAll(".grid").forEach(function (grid) {
            grid.querySelectorAll(".card.sr").forEach(function (card, i) {
              card.style.transitionDelay = Math.min(i * 42, 180) + "ms";
            });
          });
        });
      })();
    </script>
  </body>
