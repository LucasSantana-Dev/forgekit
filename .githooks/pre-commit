#!/usr/bin/env sh
set -e

top_level=$(git rev-parse --show-toplevel)
cd "$top_level"

if command -v pnpm >/dev/null 2>&1; then
  pnpm run catalog:llms
else
  echo "Error: pnpm is not installed. Install pnpm and rerun the commit." >&2
  exit 1
fi

git diff --quiet -- llms.txt || {
  echo "" >&2
  echo "llms.txt was updated by the pre-commit hook. Please review and stage the changes before committing." >&2
  echo "" >&2
  exit 1
}
