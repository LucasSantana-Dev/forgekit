{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucassantana-dev.github.io/ai-dev-toolkit/packages/catalog/schemas/skill.schema.json",
  "title": "Skill",
  "description": "An actionable procedure installable into a Claude-compatible agent's skills directory.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Slug: lowercase, hyphen-separated, 2-64 chars."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$",
      "description": "Semver."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true
    },
    "editors": {
      "type": "array",
      "description": "Which editors this skill applies to. Empty or omitted = generic.",
      "items": {
        "enum": [
          "claude-code",
          "claude-api",
          "claude-ai",
          "codex",
          "cursor",
          "windsurf",
          "opencode",
          "gemini",
          "github-copilot",
          "antigravity"
        ]
      },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "git",
            "local",
            "vendored"
          ]
        },
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "copy_to": {
          "type": "string",
          "description": "Destination directory (supports ~). Defaults to ~/.claude/skills/<id>/."
        },
        "post_install": {
          "type": "array",
          "description": "Optional shell commands run after copy. Use sparingly; must be idempotent.",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "maxLength": 64
    },
    "author": {
      "type": "string",
      "maxLength": 128
    },
    "deprecated": {
      "type": "boolean",
      "default": false
    },
    "translations": {
      "type": "object",
      "description": "Optional locale-specific overrides for user-visible fields. Keys are BCP-47 language tags.",
      "additionalProperties": false,
      "properties": {
        "pt-BR": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
