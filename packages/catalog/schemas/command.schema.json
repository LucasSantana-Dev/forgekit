{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucassantana-dev.github.io/ai-dev-toolkit/packages/catalog/schemas/command.schema.json",
  "title": "Command",
  "description": "A Claude Code slash command (markdown body with YAML frontmatter), installed into ~/.claude/commands/<id>.md.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true
    },
    "category": {
      "type": "string",
      "description": "Optional grouping label (e.g. productivity, quality, security).",
      "maxLength": 40
    },
    "argument_hint": {
      "type": "string",
      "description": "Short text shown as hint when the user types the slash command.",
      "maxLength": 200
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "git",
            "local",
            "vendored"
          ]
        },
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "maxLength": 64
    },
    "author": {
      "type": "string",
      "maxLength": 128
    },
    "deprecated": {
      "type": "boolean",
      "default": false
    },
    "translations": {
      "type": "object",
      "description": "Optional locale-specific overrides for user-visible fields. Keys are BCP-47 language tags.",
      "additionalProperties": false,
      "properties": {
        "pt-BR": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
