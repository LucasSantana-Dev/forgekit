{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucassantana-dev.github.io/ai-dev-toolkit/packages/catalog/schemas/collection.schema.json",
  "title": "Collection",
  "description": "An opinionated bundle of catalog items (skills and/or servers).",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "skill",
              "server",
              "doc",
              "agent",
              "hook",
              "command",
              "tool"
            ]
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "maxItems": 16,
      "uniqueItems": true
    },
    "translations": {
      "type": "object",
      "description": "Optional locale-specific overrides for user-visible fields. Keys are BCP-47 language tags.",
      "additionalProperties": false,
      "properties": {
        "pt-BR": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
