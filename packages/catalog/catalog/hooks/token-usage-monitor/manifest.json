{
  "id": "token-usage-monitor",
  "name": "Token Usage Monitor",
  "description": "Token Usage Monitoring Hook Monitors and reports on token usage patterns",
  "version": "0.1.0",
  "tags": [
    "hook",
    "claude-code",
    "token-optimization"
  ],
  "event": "any",
  "runtime": "bash",
  "install": {
    "copy_to": "~/.claude/hooks/token-usage-monitor.sh",
    "chmod_exec": true
  },
  "source": {
    "type": "local",
    "path": "~/.claude/hooks/productivity/token-usage-monitor.sh"
  },
