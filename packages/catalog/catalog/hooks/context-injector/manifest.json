{
  "id": "context-injector",
  "name": "Context Injector",
  "description": "Context injection hook for Claude Code Injects relevant context based on user prompt analysis",
  "version": "0.1.0",
  "tags": [
    "hook",
    "claude-code",
    "token-optimization"
  ],
  "event": "any",
  "runtime": "bash",
  "install": {
    "copy_to": "~/.claude/hooks/context-injector.sh",
    "chmod_exec": true
  },
  "source": {
    "type": "local",
    "path": "~/.claude/hooks/productivity/context-injector.sh"
  },
  "license": "MIT",
