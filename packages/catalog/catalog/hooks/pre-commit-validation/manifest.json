{
  "id": "pre-commit-validation",
  "name": "Pre Commit Validation",
  "description": "Pre-commit validation hook for UIForge MCP Runs essential checks before allowing commits",
  "version": "0.1.0",
  "tags": [
    "hook",
    "claude-code"
  ],
  "event": "any",
  "runtime": "bash",
  "install": {
    "copy_to": "~/.claude/hooks/pre-commit-validation.sh",
    "chmod_exec": true
  },
  "source": {
    "type": "local",
    "path": "~/.claude/hooks/productivity/pre-commit-validation.sh"
  },
