{
  "id": "validate-tests",
  "name": "Validate Tests",
  "description": "Validate tests after code changes Ensures test coverage and quality standards",
  "version": "0.1.0",
  "tags": [
    "hook",
    "claude-code",
    "validation"
  ],
  "event": "any",
  "runtime": "bash",
  "install": {
    "copy_to": "~/.claude/hooks/validate-tests.sh",
    "chmod_exec": true
  },
  "source": {
    "type": "local",
    "path": "~/.claude/hooks/quality/validate-tests.sh"
  },
  "license": "MIT",
  "author": "Lucas Santana"
}
