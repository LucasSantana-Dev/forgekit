{
  "$schema": "../schema/providers.schema.json",
  "version": "1.0.0",
  "providers": {
    "anthropic": {
      "name": "Anthropic",
      "env_key": "ANTHROPIC_API_KEY",
      "base_url": "https://api.anthropic.com",
      "models": {
        "haiku": "claude-haiku-4-5-20251001",
        "sonnet": "claude-sonnet-4-6",
        "opus": "claude-opus-4-6"
      }
    },
    "openai": {
      "name": "OpenAI",
      "env_key": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "models": {
        "haiku": "gpt-5.4-mini",
        "sonnet": "gpt-5.4",
        "opus": "gpt-5-codex"
      }
    },
    "google": {
      "name": "Google",
      "env_key": "GOOGLE_API_KEY",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "models": {
        "haiku": "gemini-2.0-flash",
        "sonnet": "gemini-2.5-pro",
        "opus": "gemini-2.5-pro"
      }
    },
    "ollama": {
      "name": "Ollama (local)",
      "env_key": "",
      "base_url": "http://localhost:11434",
      "models": {
        "haiku": "qwen2.5-coder:7b",
        "sonnet": "qwen2.5-coder:14b",
        "opus": "qwen2.5-coder:32b"
      },
      "notes": "No API key required. Run: ollama pull qwen2.5-coder:14b"
    },
    "openrouter": {
      "name": "OpenRouter",
      "env_key": "OPENROUTER_API_KEY",
      "base_url": "https://openrouter.ai/api/v1",
      "models": {
        "haiku": "anthropic/claude-haiku-4-5",
        "sonnet": "anthropic/claude-sonnet-4-6",
        "opus": "anthropic/claude-opus-4-6"
      },
      "notes": "Unified access to 200+ models. Useful for fallback routing."
    }
  },
  "default_provider": "anthropic",
  "fallback_chain": ["anthropic", "openrouter", "ollama"]
}
