{
  "$schema": "../schema/mcp.schema.json",
  "version": "2.0.0",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "description": "Library docs \u2014 fetch up-to-date docs for any npm/pip package",
      "required_env": [],
      "profile": "standard",
      "category": "research"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Structured reasoning \u2014 chain-of-thought problem solving",
      "required_env": [],
      "profile": "standard",
      "category": "reasoning"
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "description": "Web search \u2014 current events, docs, research",
      "required_env": [
        "TAVILY_API_KEY"
      ],
      "profile": "standard",
      "category": "research"
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "description": "Persistent knowledge graph \u2014 cross-session memory",
      "required_env": [],
      "profile": "standard",
      "category": "memory"
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "description": "HTTP fetch \u2014 retrieve and parse web content",
      "required_env": [],
      "profile": "standard",
      "category": "research"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${HOME}"
      ],
      "description": "File system access beyond the project directory",
      "required_env": [],
      "profile": "full",
      "category": "tools"
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ],
      "description": "Git operations \u2014 status, diff, log, commit, branch",
      "required_env": [],
      "profile": "standard",
      "category": "tools"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub API \u2014 issues, PRs, search, repos",
      "required_env": [
        "GITHUB_TOKEN"
      ],
      "profile": "full",
      "category": "tools"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "description": "Browser automation \u2014 screenshot, click, form fill, E2E",
      "required_env": [],
      "profile": "full",
      "category": "testing"
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "description": "Web scraping \u2014 extract structured data from URLs",
      "required_env": [
        "FIRECRAWL_API_KEY"
      ],
      "profile": "full",
      "category": "research"
    }
  },
  "profiles": {
    "standard": {
      "description": "Essential servers for everyday development",
      "servers": [
        "context7",
        "sequential-thinking",
        "tavily",
        "memory",
        "fetch",
        "git"
      ]
    },
    "full": {
      "description": "All servers including browser, filesystem, and GitHub",
      "servers": [
        "context7",
        "sequential-thinking",
        "tavily",
        "memory",
        "fetch",
        "git",
        "filesystem",
        "github",
        "playwright",
        "firecrawl"
      ]
    },
    "minimal": {
      "description": "Bare minimum \u2014 just docs and search",
      "servers": [
        "context7",
        "fetch"
      ]
    }
  },
  "agentMapping": {
    "researcher": [
      "context7",
      "tavily",
      "fetch",
      "firecrawl"
    ],
    "explorer": [
      "context7"
    ],
    "worker": [
      "git",
      "filesystem"
    ],
    "devops": [
      "git",
      "github"
    ],
    "tester": [
      "playwright"
    ],
    "orchestrator": [
      "git",
      "github",
      "memory"
    ],
    "writer": [
      "context7",
      "fetch"
    ]
  }
}
