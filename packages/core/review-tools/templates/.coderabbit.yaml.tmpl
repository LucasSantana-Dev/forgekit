# CodeRabbit configuration
# Docs: https://docs.coderabbit.ai/getting-started/configure-coderabbit
#
# Goal: chill profile so minor/nit comments are summarized rather than
# threaded as actionable. Real bugs still flagged. The merge rule in
# ~/.claude/standards/workflow.md gates on substantive concerns only.
language: en-US

reviews:
  profile: chill
  request_changes_workflow: false
  high_level_summary: true
  poem: false
  review_status: false
  collapse_walkthrough: true
  path_filters:
    - '!**/*.lock'
    - '!**/package-lock.json'
    - '!**/dist/**'
    - '!**/build/**'
    - '!**/.next/**'
    - '!**/generated/**'
    - '!**/__generated__/**'
    - '!**/CHANGELOG.md'
    - '!**/*.snap'
  auto_review:
    enabled: true
    drafts: false
    base_branches:
      - main
      - 'release/.*'

chat:
  auto_reply: false

knowledge_base:
  learnings:
    scope: auto
  issues:
    scope: auto
