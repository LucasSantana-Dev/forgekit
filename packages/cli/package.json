{
  "name": "forge-kit",
  "version": "0.3.0",
  "description": "Forge Kit CLI: browse and install skills, agents, hooks, tools, and MCP servers.",
  "keywords": ["mcp", "claude", "skills", "ai", "cli", "forge-kit"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "forge-kit": "./dist/index.js",
    "adtl": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LucasSantana-Dev/forgekit.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
